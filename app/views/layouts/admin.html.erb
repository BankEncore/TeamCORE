<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "TeamCORE Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="tc-workspace antialiased" style="color: var(--tc-text);">
    <%= render "admin/nav" %>
    <main class="tc-workspace__body">
      <%= render "admin/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
