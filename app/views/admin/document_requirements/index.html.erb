<% content_for :title, "Document requirements — TeamCORE Admin" %>
<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-semibold">Document requirements</h1>
  <%= link_to "New requirement", new_admin_document_requirement_path, class: "rounded bg-slate-900 text-white px-3 py-2 text-sm" %>
</div>
<table class="min-w-full text-sm border border-slate-200 bg-white rounded-lg overflow-hidden">
  <thead class="bg-slate-100"><tr>
    <th class="text-left p-2">ID</th>
    <th class="text-left p-2">Name</th>
    <th class="text-left p-2">Type</th>
    <th class="text-left p-2">Scope</th>
    <th class="text-left p-2">Relationship</th>
    <th class="text-left p-2">Required</th>
    <th class="text-left p-2">Status</th>
  </tr></thead>
  <tbody>
    <% @document_requirements.each do |req| %>
      <tr class="border-t border-slate-200">
        <td class="p-2"><%= link_to req.id, edit_admin_document_requirement_path(req), class: "text-sky-700 underline" %></td>
        <td class="p-2"><%= req.name.presence || "—" %></td>
        <td class="p-2"><%= req.document_type&.code %></td>
        <td class="p-2"><%= req.requirement_scope %></td>
        <td class="p-2"><%= req.relationship_type %></td>
        <td class="p-2"><%= req.required %></td>
        <td class="p-2"><%= req.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>
