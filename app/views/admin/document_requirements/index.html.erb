<% content_for :title, "Document requirements — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Setup</p>
      <h1 class="tc-page-header__title">Document requirements</h1>
      <p class="tc-page-header__subtitle">Rules that drive document readiness by scope and relationship.</p>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "New requirement", new_admin_document_requirement_path, class: "tc-btn tc-btn--primary" %>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table tc-data-table--compact">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Type</th>
          <th>Scope</th>
          <th>Relationship</th>
          <th>Required</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @document_requirements.each do |req| %>
          <tr>
            <td class="tc-data-table__primary font-mono text-xs"><%= link_to req.id, edit_admin_document_requirement_path(req), class: tc_link_classes %></td>
            <td><%= req.name.presence || "—" %></td>
            <td class="tc-data-table__cell-muted font-mono text-xs"><%= req.document_type&.code %></td>
            <td class="font-mono text-xs"><%= req.requirement_scope %></td>
            <td class="font-mono text-xs"><%= req.relationship_type %></td>
            <td><%= req.required %></td>
            <td><span class="<%= tc_status_badge_classes(req.status) %>"><%= req.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
