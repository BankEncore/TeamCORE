<%= render "shared/errors", model: @location %>
<%= form_with model: [:admin, @location], data: { turbo: false } do |f| %>
  <div class="mb-3">
    <%= f.label :code, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :code, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :location_type, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :location_type, Location::LOCATION_TYPES, {}, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :timezone, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :timezone, class: "w-full border border-slate-300 rounded px-3 py-2", placeholder: "e.g. America/New_York" %>
  </div>
  <div class="mb-3">
    <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-4">
    <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :status, LifecycleStatusable::STATUSES, {}, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <%= f.submit class: "rounded bg-slate-900 text-white px-4 py-2 text-sm cursor-pointer" %>
<% end %>
