<% content_for :title, "Locations — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Organization</p>
      <h1 class="tc-page-header__title">Locations</h1>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "New location", new_admin_location_path, class: "tc-btn tc-btn--primary" %>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>Type</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @locations.each do |loc| %>
          <tr>
            <td class="tc-data-table__primary"><%= link_to loc.code, admin_location_path(loc), class: tc_link_classes %></td>
            <td><%= loc.name %></td>
            <td class="tc-data-table__cell-muted"><%= loc.location_type %></td>
            <td><span class="<%= tc_status_badge_classes(loc.status) %>"><%= loc.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
