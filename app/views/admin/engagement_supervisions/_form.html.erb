<%= render "shared/errors", model: @assignment %>
<%= form_with model: @assignment,
      url: @assignment.persisted? ? admin_engagement_supervision_assignment_path(@engagement, @assignment) : admin_engagement_supervision_assignments_path(@engagement),
      method: @assignment.persisted? ? :patch : :post,
      data: { turbo: false } do |f| %>
  <%= f.hidden_field :relationship_type, value: "primary_reports_to" %>
  <div class="mb-4">
    <%= f.label :supervisor_engagement_id, "Supervisor (active employee engagement)", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :supervisor_engagement_id,
          options_from_collection_for_select(
            @supervisor_engagements,
            :id,
            ->(eg) { "Eng #{eg.id} · #{eg.team_member.party.display_name}" }
          ),
          { prompt: "Select…" },
          class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :effective_start_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.date_field :effective_start_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :effective_end_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.date_field :effective_end_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-4">
    <%= f.label :notes, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :notes, rows: 2, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <%= f.submit class: "rounded bg-slate-900 text-white px-4 py-2 text-sm cursor-pointer" %>
<% end %>
