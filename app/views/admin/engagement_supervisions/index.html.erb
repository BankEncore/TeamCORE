<% content_for :title, "Supervision — E##{@engagement.id}" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Engagement</p>
      <h1 class="tc-page-header__title">Supervision</h1>
      <p class="tc-page-header__subtitle">Engagement #<%= @engagement.id %></p>
    </div>
    <div class="tc-page-header__actions">
      <div class="tc-action-bar">
        <%= link_to "← Engagement", admin_engagement_path(@engagement), class: "#{tc_link_classes} text-sm" %>
        <%= link_to "New supervision", new_admin_engagement_supervision_assignment_path(@engagement), class: "tc-btn tc-btn--primary" %>
      </div>
    </div>
  </header>

  <div class="tc-panel p-0">
    <ul class="m-0 divide-y list-none p-0" style="border-color: var(--tc-border);">
      <% @assignments.each do |a| %>
        <li class="px-4 py-3 text-sm">
          <%= link_to "Reports to Engagement ##{a.supervisor_engagement_id} (#{a.effective_start_on})", admin_engagement_supervision_assignment_path(@engagement, a), class: tc_link_classes %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
