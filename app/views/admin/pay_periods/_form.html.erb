<%= form_with model: [:admin, pay_period], class: "space-y-4 max-w-xl" do |f| %>
  <% if pay_period.errors.any? %>
    <div class="text-red-600 text-sm"><%= pay_period.errors.full_messages.join(", ") %></div>
  <% end %>
  <div class="tc-field">
    <%= f.label :label, class: "tc-label" %>
    <%= f.text_field :label, class: "tc-input" %>
  </div>
  <p class="text-xs text-slate-500">Period dates are generated by the payroll calendar and cannot be edited here.</p>
  <%= f.submit class: "tc-btn tc-btn--primary" %>
<% end %>
