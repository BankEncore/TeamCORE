<% content_for :title, "Configuration — #{current_agency.name}" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Workspace</p>
      <h1 class="tc-page-header__title">Configuration</h1>
      <p class="tc-page-header__subtitle">
        Agency structure and setup catalogs — links open existing admin CRUD (no new domain behavior).
      </p>
    </div>
  </header>

  <div class="tc-panel">
    <div class="tc-panel__header">
      <div class="tc-panel__title">Launch</div>
    </div>
    <div class="tc-panel__body text-sm space-y-2">
      <ul class="m-0 list-none space-y-2 p-0">
        <li><%= link_to "Agencies", admin_agencies_path, class: tc_link_classes %></li>
        <li><%= link_to "Departments", admin_departments_path, class: tc_link_classes %></li>
        <li><%= link_to "Locations", admin_locations_path, class: tc_link_classes %></li>
        <li><%= link_to "Teams", admin_teams_path, class: tc_link_classes %></li>
        <li><%= link_to "Compensation plans", admin_compensation_plans_path, class: tc_link_classes %></li>
        <li><%= link_to "Document types", admin_document_types_path, class: tc_link_classes %></li>
        <li><%= link_to "Document requirements", admin_document_requirements_path, class: tc_link_classes %></li>
      </ul>
    </div>
  </div>
</div>
