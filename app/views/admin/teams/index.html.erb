<% content_for :title, "Teams — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Organization</p>
      <h1 class="tc-page-header__title">Teams</h1>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "New team", new_admin_team_path, class: "tc-btn tc-btn--primary" %>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @teams.each do |t| %>
          <tr>
            <td class="tc-data-table__primary"><%= link_to t.code, admin_team_path(t), class: tc_link_classes %></td>
            <td><%= t.name %></td>
            <td><span class="<%= tc_status_badge_classes(t.status) %>"><%= t.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
