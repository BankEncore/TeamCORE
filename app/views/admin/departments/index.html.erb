<% content_for :title, "Departments — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Organization</p>
      <h1 class="tc-page-header__title">Departments</h1>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "New department", new_admin_department_path, class: "tc-btn tc-btn--primary" %>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @departments.each do |d| %>
          <tr>
            <td class="tc-data-table__primary"><%= link_to d.code, admin_department_path(d), class: tc_link_classes %></td>
            <td><%= d.name %></td>
            <td><span class="<%= tc_status_badge_classes(d.status) %>"><%= d.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
