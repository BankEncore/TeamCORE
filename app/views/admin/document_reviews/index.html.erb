<% content_for :title, "Pending document review — TeamCORE Admin" %>
<div class="mb-4 flex flex-wrap gap-3 items-center">
  <%= link_to "← Dashboard", admin_root_path, class: "text-sky-700 text-sm" %>
  <%= link_to "All document records", admin_document_records_path, class: "text-sky-700 text-sm" %>
</div>
<h1 class="text-2xl font-semibold mb-2">Pending document review</h1>
<p class="text-sm text-slate-600 mb-4">Submitted records in the current agency awaiting review (exception worklist, not reporting).</p>

<%= form_with url: admin_document_reviews_path, method: :get, data: { turbo: false }, class: "border border-slate-200 rounded p-4 bg-white mb-6 space-y-3 text-sm" do %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
    <div>
      <%= label_tag :document_type_id, "Document type", class: "block text-slate-600 text-xs mb-1" %>
      <%= select_tag :document_type_id,
            options_from_collection_for_select(@document_types, :id, :name, params[:document_type_id]),
            include_blank: "— any —",
            class: "w-full border border-slate-300 rounded px-2 py-1" %>
    </div>
    <div>
      <%= label_tag :team_member_id, "Team member id", class: "block text-slate-600 text-xs mb-1" %>
      <%= text_field_tag :team_member_id, params[:team_member_id], class: "w-full border border-slate-300 rounded px-2 py-1", placeholder: "numeric" %>
    </div>
    <div>
      <%= label_tag :engagement_id, "Engagement id", class: "block text-slate-600 text-xs mb-1" %>
      <%= text_field_tag :engagement_id, params[:engagement_id], class: "w-full border border-slate-300 rounded px-2 py-1", placeholder: "numeric" %>
    </div>
    <div>
      <%= label_tag :relationship_type, "Engagement relationship", class: "block text-slate-600 text-xs mb-1" %>
      <%= select_tag :relationship_type,
            options_for_select([ [ "— any —", "" ] ] + Engagement::RELATIONSHIP_TYPES.map { |t| [ t, t ] }, params[:relationship_type]),
            class: "w-full border border-slate-300 rounded px-2 py-1" %>
    </div>
    <div>
      <%= label_tag :submitted_on_from, "Submitted from (ISO)", class: "block text-slate-600 text-xs mb-1" %>
      <%= text_field_tag :submitted_on_from, params[:submitted_on_from], class: "w-full border border-slate-300 rounded px-2 py-1" %>
    </div>
    <div>
      <%= label_tag :submitted_on_to, "Submitted to (ISO)", class: "block text-slate-600 text-xs mb-1" %>
      <%= text_field_tag :submitted_on_to, params[:submitted_on_to], class: "w-full border border-slate-300 rounded px-2 py-1" %>
    </div>
    <div>
      <%= label_tag :expires_on_from, "Expires from (ISO)", class: "block text-slate-600 text-xs mb-1" %>
      <%= text_field_tag :expires_on_from, params[:expires_on_from], class: "w-full border border-slate-300 rounded px-2 py-1" %>
    </div>
    <div>
      <%= label_tag :expires_on_to, "Expires to (ISO)", class: "block text-slate-600 text-xs mb-1" %>
      <%= text_field_tag :expires_on_to, params[:expires_on_to], class: "w-full border border-slate-300 rounded px-2 py-1" %>
    </div>
  </div>
  <div class="flex gap-2">
    <%= submit_tag "Apply filters", class: "rounded bg-slate-900 text-white px-3 py-2 text-sm cursor-pointer" %>
    <%= link_to "Reset", admin_document_reviews_path, class: "text-sky-700 text-sm py-2" %>
  </div>
<% end %>

<% if @document_records.empty? %>
  <p class="text-sm text-slate-600">No submitted documents match the filters.</p>
<% else %>
  <div class="overflow-x-auto border border-slate-200 rounded bg-white">
    <table class="min-w-full text-xs">
      <thead class="bg-slate-100">
        <tr>
          <th class="text-left p-2">Record</th>
          <th class="text-left p-2">Type</th>
          <th class="text-left p-2">Verification required<br><span class="font-normal text-slate-600">(on type)</span></th>
          <th class="text-left p-2">Team member</th>
          <th class="text-left p-2">Engagement</th>
          <th class="text-left p-2">Relationship</th>
          <th class="text-left p-2">Submitted</th>
          <th class="text-left p-2">Expires</th>
        </tr>
      </thead>
      <tbody>
        <% @document_records.each do |rec| %>
          <tr class="border-t border-slate-200">
            <td class="p-2"><%= link_to "##{rec.id}", admin_document_record_path(rec), class: "text-sky-700 underline font-mono" %></td>
            <td class="p-2"><%= rec.document_type&.name %> <span class="text-slate-500">(<%= rec.document_type&.code %>)</span></td>
            <td class="p-2 font-mono"><%= rec.document_type&.verification_required ? "yes" : "no" %></td>
            <td class="p-2"><%= rec.team_member_id %> <%= rec.team_member&.party&.display_name %></td>
            <td class="p-2 font-mono"><%= rec.engagement_id || "—" %></td>
            <td class="p-2 font-mono"><%= rec.engagement&.relationship_type || "—" %></td>
            <td class="p-2 font-mono"><%= rec.submitted_on %></td>
            <td class="p-2 font-mono"><%= rec.expires_on || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
