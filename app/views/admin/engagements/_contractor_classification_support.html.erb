<%# locals: presenter — Admin::ContractorClassificationSupportPresenter %>
<section id="contractor-classification-support" class="tc-panel mb-4">
  <div class="tc-panel__header">
    <div>
      <div class="tc-panel__title">Contractor classification support (TC-09)</div>
      <p class="tc-panel__subtitle">
        Supporting records and readiness only — not a legal classification determination.
        As of <span class="font-mono"><%= presenter.as_of_date %></span>.
      </p>
    </div>
  </div>
  <div class="tc-panel__body">
    <h3 class="mb-2 text-sm font-semibold" style="color: var(--tc-text);">Identity / entity context</h3>
    <dl class="tc-kv-grid mb-4">
      <% presenter.identity_rows.each do |label, value| %>
        <div class="tc-kv">
          <dt class="tc-kv__key"><%= label %></dt>
          <dd class="tc-kv__value"><%= value %></dd>
        </div>
      <% end %>
    </dl>

    <div class="mb-4">
      <h3 class="mb-1 text-sm font-semibold" style="color: var(--tc-text);">Classification support status</h3>
      <span class="<%= tc_readiness_badge_classes(presenter.readiness_status) %>"><%= presenter.readiness_status %></span>
    </div>

    <% rollups = presenter.category_rollups %>
    <% if rollups.any? %>
      <h3 class="mb-2 text-sm font-semibold" style="color: var(--tc-text);">By document category (rollup)</h3>
      <div class="tc-table-wrap mb-4">
        <table class="tc-data-table tc-data-table--compact text-xs">
          <thead>
            <tr>
              <th>Category</th>
              <th>Rollup outcome</th>
              <th>Requirements</th>
            </tr>
          </thead>
          <tbody>
            <% rollups.each do |rollup| %>
              <tr class="align-top">
                <td class="font-mono"><%= rollup.category %></td>
                <td class="font-mono"><%= rollup.rollup_outcome %></td>
                <td>
                  <ul class="list-disc space-y-1 pl-4">
                    <% rollup.rows.each do |row| %>
                      <li>
                        <%= link_to "Req ##{row.document_requirement_id}", edit_admin_document_requirement_path(row.document_requirement_id), class: tc_link_classes %>
                        · <span class="font-mono"><%= row.requirement_outcome %></span>
                        <% if row.document_record_id.present? %>
                          · <%= link_to "Record ##{row.document_record_id}", admin_document_record_path(row.document_record_id), class: tc_link_classes %>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</section>
