<% content_for :title, "Engagement ##{@engagement.id}" %>
<div class="tc-page-stack">
  <p class="text-sm"><%= link_to "← Engagements", admin_engagements_path, class: tc_link_classes %></p>

  <header class="tc-record-header">
    <div class="tc-record-header__top">
      <div>
        <div class="tc-record-header__eyebrow">Engagement</div>
        <h1 class="tc-record-header__title">Engagement #<%= @engagement.id %></h1>
        <p class="tc-record-header__subtitle">
          <%= link_to @engagement.team_member.party.display_name, admin_team_member_path(@engagement.team_member), class: "text-white underline decoration-white/50 hover:decoration-white" %>
        </p>
        <div class="tc-record-header__badges">
          <span class="tc-badge tc-badge--secondary"><%= @engagement.relationship_type %></span>
          <span class="<%= tc_status_badge_classes(@engagement.status) %>"><%= @engagement.status %></span>
        </div>
      </div>
      <div class="tc-record-header__actions">
        <%= link_to "Team360", admin_team_member_team360_path(@engagement.team_member), class: "tc-btn tc-btn--teal" %>
        <%= link_to "Placements", admin_engagement_placements_path(@engagement), class: "tc-btn tc-btn--secondary" %>
        <%= link_to "Supervision", admin_engagement_supervision_assignments_path(@engagement), class: "tc-btn tc-btn--secondary" %>
        <%= link_to "Edit", edit_admin_engagement_path(@engagement), class: "tc-btn tc-btn--primary" %>
      </div>
    </div>
  </header>

  <div class="tc-record-layout">
    <section class="tc-record-main">
      <% if @engagement.relationship_type == "subcontractor" %>
        <section class="tc-panel">
          <div class="tc-panel__header">
            <div>
              <div class="tc-panel__title">Contractor association context</div>
              <p class="tc-panel__subtitle">Subcontractor PartyRelationships targeting this team member&apos;s party.</p>
            </div>
          </div>
          <div class="tc-panel__body">
            <% if @subcontractor_context_rels.blank? %>
              <p class="text-sm" style="color: var(--tc-text-muted);">No matching subcontractor PartyRelationship rows for this party in this agency.</p>
            <% else %>
              <ul class="m-0 list-none space-y-2 p-0 text-sm">
                <% @subcontractor_context_rels.each do |rel| %>
                  <li>
                    <span class="font-mono text-xs" style="color: var(--tc-text-muted);">source → target</span>
                    <%= rel.source_party.display_name.presence || "Party ##{rel.source_party_id}" %> → <%= @engagement.team_member.party.display_name %>
                    · <span class="<%= tc_status_badge_classes(rel.status) %>"><%= rel.status %></span>
                    <% if rel.effective_start_date || rel.effective_end_date %>
                      · eff. <%= rel.effective_start_date || "—" %> — <%= rel.effective_end_date || "—" %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if @contractor_classification_support.present? %>
        <%= render partial: "contractor_classification_support", locals: { presenter: @contractor_classification_support } %>
      <% end %>

      <% if @engagement.title.present? || @engagement.notes.present? %>
        <section class="tc-panel">
          <div class="tc-panel__header">
            <div class="tc-panel__title">Notes</div>
          </div>
          <div class="tc-panel__body text-sm">
            <% if @engagement.title.present? %><p class="font-medium" style="color: var(--tc-text);"><%= @engagement.title %></p><% end %>
            <% if @engagement.notes.present? %><div style="color: var(--tc-text-muted);"><%= simple_format(@engagement.notes) %></div><% end %>
          </div>
        </section>
      <% end %>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div>
            <div class="tc-panel__title">Document readiness</div>
            <p class="tc-panel__subtitle">
              <code class="font-mono text-xs">Documents::ReadinessEvaluator</code> ·
              <span class="<%= tc_readiness_badge_classes(@document_readiness.readiness_status) %>"><%= @document_readiness.readiness_status %></span>
              · as of <%= @document_readiness.as_of_date %>
            </p>
          </div>
        </div>
        <div class="tc-panel__body">
          <%= render partial: "document_alerts", locals: { readiness: @document_readiness, document_types_by_id: @document_types_by_id } %>
          <h3 class="mb-2 mt-6 text-sm font-semibold" style="color: var(--tc-text);">Requirements</h3>
          <div class="tc-table-wrap">
            <table class="tc-data-table tc-data-table--compact text-xs">
              <thead>
                <tr>
                  <th>Req</th>
                  <th>Scope</th>
                  <th>Rel.</th>
                  <th>Required</th>
                  <th>Outcome</th>
                  <th>Record review</th>
                  <th>Record</th>
                </tr>
              </thead>
              <tbody>
                <% @document_readiness.requirements.each do |row| %>
                  <tr>
                    <td class="font-mono"><%= row.document_requirement_id %></td>
                    <td><%= row.requirement_scope %></td>
                    <td class="font-mono"><%= row.relationship_type %></td>
                    <td><%= row.required %></td>
                    <td class="font-mono"><%= row.requirement_outcome %></td>
                    <td class="font-mono"><%= row.record_review_status || "—" %></td>
                    <td class="font-mono"><%= row.document_record_id || "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Placements</div>
        </div>
        <div class="tc-panel__body">
          <% if @placement_rows.empty? %>
            <p class="text-sm" style="color: var(--tc-text-muted);">No placements.</p>
          <% else %>
            <ul class="m-0 list-none space-y-1 p-0 text-sm">
              <% @placement_rows.each do |p| %>
                <li class="font-mono text-xs"><%= p.effective_start_on %> — <%= p.effective_end_on %> · dept <%= p.department_id %> · loc <%= p.location_id %> · team <%= p.team_id %></li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Supervision assignments</div>
        </div>
        <div class="tc-panel__body">
          <% if @supervision_rows.empty? %>
            <p class="text-sm" style="color: var(--tc-text-muted);">No supervision rows.</p>
          <% else %>
            <ul class="m-0 list-none space-y-1 p-0 text-sm">
              <% @supervision_rows.each do |s| %>
                <li class="text-xs">
                  <%= s.relationship_type %> supervisor engagement <%= s.supervisor_engagement_id %> · <%= s.effective_start_on %> — <%= s.effective_end_on %>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>
    </section>

    <aside class="tc-record-context tc-record-context--sticky">
      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Quick facts</div>
        </div>
        <div class="tc-panel__body">
          <dl class="tc-kv-grid tc-kv-grid--single">
            <div class="tc-kv">
              <dt class="tc-kv__key">Team member</dt>
              <dd class="tc-kv__value"><%= link_to @engagement.team_member.id, admin_team_member_path(@engagement.team_member), class: tc_link_classes %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Dates</dt>
              <dd class="tc-kv__value font-mono text-xs">start <%= @engagement.start_on %> · end <%= @engagement.end_on %> · exp <%= @engagement.expected_end_on %></dd>
            </div>
          </dl>
        </div>
      </section>

      <section class="tc-panel tc-panel--muted">
        <div class="tc-panel__header">
          <div>
            <div class="tc-panel__title">Workflow hints</div>
            <p class="tc-panel__subtitle">Eligibility flags for operators — not persistence.</p>
          </div>
        </div>
        <div class="tc-panel__body text-sm space-y-2" style="color: var(--tc-text-muted);">
          <p>employee path? <span class="font-mono" style="color: var(--tc-text);"><%= @engagement.employee_path? %></span> · contractor class? <span class="font-mono" style="color: var(--tc-text);"><%= @engagement.contractor_class? %></span></p>
          <p>suspended? <span class="font-mono" style="color: var(--tc-text);"><%= @engagement.suspended? %></span> · terminal? <span class="font-mono" style="color: var(--tc-text);"><%= @engagement.terminal? %></span></p>
          <p>blocked forward (status)? <span class="font-mono" style="color: var(--tc-text);"><%= @engagement.operational_forward_work_blocked_by_status? %></span></p>
        </div>
      </section>
    </aside>
  </div>
</div>
