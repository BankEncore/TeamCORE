<%= form_with model: [:admin, engagement, charge], class: "space-y-4 max-w-xl" do |f| %>
  <% if charge.errors.any? %>
    <div class="text-red-600 text-sm"><%= charge.errors.full_messages.join(", ") %></div>
  <% end %>
  <div class="tc-field">
    <%= f.label :charge_type, class: "tc-label" %>
    <%= f.select :charge_type,
          options_for_select(
            ContractorCharge.charge_type_select_values(charge.charge_type).map { |t| [ t.humanize, t ] },
            charge.charge_type
          ),
          {},
          class: "tc-select" %>
  </div>
  <div class="tc-field">
    <%= f.label :status, class: "tc-label" %>
    <%= f.select :status,
          options_for_select(ContractorCharge::STATUSES.map { |s| [ s.humanize, s ] }, charge.status),
          {},
          class: "tc-select" %>
  </div>
  <div class="tc-field">
    <%= f.label :original_amount_money, "Original amount", class: "tc-label" %>
    <%= f.text_field :original_amount_money, class: "tc-input", placeholder: "0.00", inputmode: "decimal", autocomplete: "off" %>
  </div>
  <div class="tc-field">
    <%= f.label :open_balance_money, "Open balance", class: "tc-label" %>
    <%= f.text_field :open_balance_money, class: "tc-input", placeholder: "0.00", inputmode: "decimal", autocomplete: "off" %>
  </div>
  <div class="tc-field">
    <%= f.label :due_on, class: "tc-label" %>
    <%= f.date_field :due_on, class: "tc-input" %>
  </div>
  <div class="tc-field">
    <%= f.label :description, class: "tc-label" %>
    <%= f.text_area :description, class: "tc-input", rows: 3 %>
  </div>
  <%= f.submit class: "tc-btn tc-btn--primary" %>
<% end %>
