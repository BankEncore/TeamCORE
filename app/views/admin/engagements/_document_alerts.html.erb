<%# locals: readiness — Documents::ReadinessResult, document_types_by_id — Hash<Integer, DocumentType>
    Optional: team_member, engagement, return_to, team360_return_to, as_of_date (TC-UX-DOC-01 intake CTAs) %>
<% ctx_engagement = local_assigns[:engagement] %>
<% ctx_team_member = local_assigns[:team_member] || ctx_engagement&.team_member %>
<% ctx_return_to = local_assigns[:return_to] %>
<% ctx_team360_return_to = local_assigns[:team360_return_to] %>
<% ctx_as_of_date = local_assigns.fetch(:as_of_date, readiness.as_of_date) %>
<% show_actions = ctx_engagement.present? && ctx_team_member.present? %>

<div class="space-y-4">
  <div>
    <h3 class="text-sm font-semibold" style="color: var(--tc-text);">Document alerts (TC-07)</h3>
    <p class="text-xs mt-1" style="color: var(--tc-text-muted);">
      Derived from <code class="font-mono">Documents::ReadinessEvaluator</code> ·
      <span class="<%= tc_readiness_badge_classes(readiness.readiness_status) %>"><%= readiness.readiness_status %></span>
      · as of <%= readiness.as_of_date %>
    </p>
  </div>

  <% if readiness.alerts.empty? %>
    <p class="text-sm" style="color: var(--tc-text-muted);">No active document alerts for this engagement.</p>
  <% else %>
    <% grouped = readiness.alerts.group_by(&:severity) %>
    <% [["blocking", "Blocking"], ["warning", "Warnings"], ["info", "Info"]].each do |sev, label| %>
      <% rows = grouped[sev] || [] %>
      <% next if rows.empty? %>
      <div>
        <h4 class="mb-2 text-xs font-semibold uppercase tracking-wide" style="color: var(--tc-text-subtle);"><%= label %></h4>
        <div class="tc-table-wrap">
          <table class="tc-data-table tc-data-table--compact text-xs">
            <thead>
              <tr>
                <th>Message</th>
                <th>Alert type</th>
                <th>Requirement</th>
                <th>Document type</th>
                <th>Record</th>
                <th>Expires</th>
                <% if show_actions %>
                  <th>Actions</th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% rows.each do |alert| %>
                <% dtype = document_types_by_id[alert.document_type_id] %>
                <% act =
                     show_actions &&
                       Documents::DocumentIntakeActions.from_alert_result(
                         alert,
                         team_member: ctx_team_member,
                         engagement: ctx_engagement,
                         document_type: dtype,
                         return_to: ctx_return_to,
                         team360_return_to: ctx_team360_return_to,
                         as_of_date: ctx_as_of_date
                       ) %>
                <tr>
                  <td class="align-top"><%= alert.message %></td>
                  <td class="align-top font-mono"><%= alert.alert_type %></td>
                  <td class="align-top">
                    <%= link_to "Req ##{alert.document_requirement_id}", edit_admin_document_requirement_path(alert.document_requirement_id), class: tc_link_classes %>
                  </td>
                  <td class="align-top">
                    <% if dtype %>
                      <%= link_to "#{dtype.name} (#{dtype.code})", admin_document_type_path(dtype), class: tc_link_classes %>
                    <% else %>
                      <span class="font-mono tc-data-table__cell-muted">type #<%= alert.document_type_id %></span>
                    <% end %>
                  </td>
                  <td class="align-top">
                    <% if alert.document_record_id.present? %>
                      <%= link_to "Record ##{alert.document_record_id}", admin_document_record_path(alert.document_record_id), class: tc_link_classes %>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <td class="align-top font-mono">
                    <% if alert.expires_on.present? %>
                      <%= alert.expires_on %>
                      <% if alert.days_until_expiration.present? %>
                        <span style="color: var(--tc-text-muted);">(<%= alert.days_until_expiration %> d)</span>
                      <% end %>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <% if show_actions %>
                    <td class="align-top space-y-1">
                      <% if act&.primary_href.present? %>
                        <%= link_to act.primary_label, act.primary_href, class: "tc-btn tc-btn--primary inline-flex text-xs py-1 px-2" %>
                      <% end %>
                      <% if act&.secondary_href.present? && act.secondary_label.present? %>
                        <div>
                          <%= link_to act.secondary_label, act.secondary_href, class: tc_link_classes(:muted) %>
                        </div>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
