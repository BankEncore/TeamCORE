<% content_for :title, "Settlement run ##{@run.id}" %>
<div class="tc-page-stack">
  <%= link_to "← Runs", admin_contractor_settlement_runs_path, class: "text-sm #{tc_link_classes}" %>
  <h1 class="text-2xl font-semibold">Settlement run #<%= @run.id %></h1>
  <p class="text-sm font-mono">Status: <%= @run.status %> · <%= @run.period_start_on %> – <%= @run.period_end_on %></p>
  <% if @run.status.in?(%w[draft calculated]) %>
    <%= button_to "Finalize", finalize_admin_contractor_settlement_run_path(@run), method: :post, class: "tc-btn tc-btn--primary" %>
  <% end %>
  <% if @run.status == "finalized" %>
    <%= form_with url: mark_paid_admin_contractor_settlement_run_path(@run), method: :post, local: true, data: { turbo: false }, class: "mt-3 flex flex-wrap gap-2 items-end max-w-xl" do %>
      <div class="tc-field flex-1 min-w-[12rem]">
        <%= label_tag :reason, "Payment note (optional)", class: "tc-label" %>
        <%= text_field_tag :reason, nil, class: "tc-input", placeholder: "Check #, date, memo" %>
      </div>
      <%= submit_tag "Mark paid", class: "tc-btn tc-btn--secondary" %>
    <% end %>
  <% end %>
  <% if @run.status.in?(%w[draft calculated finalized]) %>
    <% if @lines.empty? %>
      <%= form_with url: void_admin_contractor_settlement_run_path(@run), method: :post, local: true, data: { turbo: false }, class: "mt-3 space-y-2 max-w-xl" do %>
        <div class="tc-field">
          <%= label_tag :reason, "Void reason (optional)", class: "tc-label" %>
          <%= text_field_tag :reason, nil, class: "tc-input", placeholder: "Why this run is voided" %>
        </div>
        <%= submit_tag "Void run", class: "tc-btn tc-btn--quiet" %>
      <% end %>
    <% else %>
      <p class="text-sm text-slate-600 mt-3 max-w-xl">
        Void is unavailable while this run has composed settlement lines (charge recoveries already applied).
      </p>
    <% end %>
  <% end %>

  <h2 class="text-lg font-semibold mt-6">Lines</h2>
  <div class="tc-table-wrap">
    <table class="tc-data-table text-xs">
      <thead><tr><th>Eng</th><th>Gross</th><th>Charges</th><th>Net</th></tr></thead>
      <tbody>
        <% @lines.each do |ln| %>
          <tr>
            <td class="font-mono"><%= ln.engagement_id %></td>
            <td><%= tc_money(ln.gross_commission_cents) %></td>
            <td><%= tc_money(ln.charge_deductions_cents) %></td>
            <td><%= tc_money(ln.net_settlement_cents) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @run.status.in?(%w[calculated finalized]) %>
    <section class="mt-6 border border-slate-200 rounded p-4 max-w-xl">
      <h2 class="text-lg font-semibold mb-2">Draft settlement export</h2>
      <p class="text-sm text-slate-600 mb-3">Repeatable review export; does not change run status (TC‑20).</p>
      <div class="flex flex-wrap gap-2">
        <%= button_to "Draft CSV",
              draft_settlement_export_admin_contractor_settlement_run_path(@run),
              method: :post,
              params: { file_format: "csv" },
              class: "tc-btn tc-btn--secondary",
              data: { turbo: false } %>
        <%= button_to "Draft XLSX",
              draft_settlement_export_admin_contractor_settlement_run_path(@run),
              method: :post,
              params: { file_format: "xlsx" },
              class: "tc-btn tc-btn--secondary",
              data: { turbo: false } %>
      </div>
    </section>
  <% end %>

  <% if @run.status == "finalized" %>
    <section class="mt-6 border border-slate-200 rounded p-4 max-w-xl">
      <h2 class="text-lg font-semibold mb-2">Final settlement export</h2>
      <p class="text-sm text-slate-600 mb-3">Immutable outbound artifact for this run (one final export per run).</p>
      <div class="flex flex-wrap gap-2">
        <%= button_to "Final CSV",
              final_settlement_export_admin_contractor_settlement_run_path(@run),
              method: :post,
              params: { file_format: "csv" },
              class: "tc-btn tc-btn--primary",
              data: { turbo: false } %>
        <%= button_to "Final XLSX",
              final_settlement_export_admin_contractor_settlement_run_path(@run),
              method: :post,
              params: { file_format: "xlsx" },
              class: "tc-btn tc-btn--primary",
              data: { turbo: false } %>
      </div>
    </section>
  <% end %>

  <% if @settlement_exports.present? %>
    <h2 class="text-lg font-semibold mt-6">Settlement exports</h2>
    <div class="tc-table-wrap">
      <table class="tc-data-table text-xs">
        <thead>
          <tr>
            <th>#</th>
            <th>When</th>
            <th>Format</th>
            <th>Final?</th>
            <th>Lines</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @settlement_exports.each do |ex| %>
            <tr>
              <td class="font-mono"><%= ex.export_sequence %></td>
              <td><%= ex.exported_at&.strftime("%Y-%m-%d %H:%M") %></td>
              <td><%= ex.file_format %></td>
              <td><%= ex.is_final? ? "yes" : "draft" %></td>
              <td class="truncate max-w-[8rem]" title="<%= ex.validation_summary&.to_json %>">
                <% if ex.validation_summary.is_a?(Hash) %>
                  <%= ex.validation_summary["line_count"] || ex.validation_summary[:line_count] %>
                <% else %>
                  —
                <% end %>
              </td>
              <td>
                <% if ex.export_file.attached? %>
                  <%= link_to "Download", download_admin_contractor_settlement_export_path(ex), class: tc_link_classes %>
                <% else %>
                  —
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if @run.status.in?(%w[draft calculated]) %>
    <% eng_opts = @contractor_engagements.reject { |e| @lines.any? { |ln| ln.engagement_id == e.id } } %>
    <% if eng_opts.any? %>
      <h2 class="text-lg font-semibold mt-6">Add settlement line</h2>
      <%= form_with url: line_composer_admin_contractor_settlement_run_path(@run), method: :get, class: "flex flex-wrap gap-3 items-end max-w-xl" do %>
        <div class="tc-field flex-1 min-w-[14rem]">
          <%= label_tag :engagement_id, "Contractor engagement", class: "tc-label" %>
          <%= select_tag :engagement_id,
                options_from_collection_for_select(eng_opts, :id, ->(e) { "##{e.id} #{e.team_member.party.display_name} (#{e.relationship_type})" }),
                class: "tc-select" %>
        </div>
        <%= submit_tag "Open line composer", class: "tc-btn tc-btn--secondary" %>
      <% end %>
      <p class="text-xs text-slate-600 mt-2 max-w-xl">
        Select commissions and charges with a net preview before composing. At most one line per engagement on this run.
      </p>
    <% else %>
      <p class="text-sm text-slate-600 mt-6 max-w-xl">Every contractor engagement already has a settlement line on this run.</p>
    <% end %>
  <% end %>

  <h2 class="text-lg font-semibold mt-6">Audit trail</h2>
  <div class="tc-table-wrap">
    <table class="tc-data-table text-xs">
      <thead><tr><th>When</th><th>Event</th><th>Actor</th><th>Reason</th></tr></thead>
      <tbody>
        <% @events.each do |ev| %>
          <tr>
            <td class="font-mono whitespace-nowrap"><%= ev.created_at.in_time_zone.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= ev.event_type %></td>
            <td><%= ev.actor&.email || "—" %></td>
            <td class="max-w-xs truncate" title="<%= ev.reason %>"><%= ev.reason.presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
