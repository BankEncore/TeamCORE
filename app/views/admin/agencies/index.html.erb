<% content_for :title, "Agencies — TeamCORE Admin" %>
<h1 class="text-2xl font-semibold mb-4">Agencies you can access</h1>
<ul class="divide-y divide-slate-200 border border-slate-200 rounded-lg bg-white">
  <% @agencies.each do |agency| %>
    <li class="px-4 py-3 flex justify-between items-center">
      <span><%= agency.name %> <span class="text-slate-500 text-sm">(<%= agency.code %>)</span></span>
      <%= link_to "View", admin_agency_path(agency), class: "text-sky-700 hover:underline text-sm" %>
    </li>
  <% end %>
</ul>
