<% content_for :title, "Leave balances — Engagement ##{@engagement.id}" %>
<div class="tc-page-stack">
  <p class="text-sm">
    <%= link_to "← Engagement", admin_engagement_path(@engagement), class: tc_link_classes %>
  </p>
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Leave balances</p>
      <h1 class="tc-page-header__title"><%= @engagement.team_member.party.display_name %></h1>
      <p class="tc-page-header__subtitle">Manual adjustments only — informational balances.</p>
    </div>
  </header>

  <div class="tc-panel">
    <div class="tc-panel__header"><div class="tc-panel__title">Tracked types</div></div>
    <div class="tc-panel__body overflow-x-auto">
      <% if @tracked_types.empty? %>
        <p class="text-sm text-slate-600">No balance-tracked leave types for this agency.</p>
      <% else %>
        <table class="min-w-full text-sm">
          <thead>
            <tr class="text-left border-b" style="border-color: var(--tc-border);">
              <th class="py-2 pr-4">Type</th>
              <th class="py-2 pr-4">Balance (hours)</th>
              <th class="py-2">Adjust</th>
            </tr>
          </thead>
          <tbody>
            <% @tracked_types.each do |lt| %>
              <% bal = @balances_by_type_id[lt.id] %>
              <% hrs = bal ? bal.balance_hours : 0 %>
              <tr class="border-b align-top" style="border-color: var(--tc-border);">
                <td class="py-2 pr-4 font-mono text-xs"><%= lt.code %></td>
                <td class="py-2 pr-4"><%= hrs %></td>
                <td class="py-2">
                  <%= form_with url: admin_engagement_leave_balances_path(@engagement), method: :post, class: "flex flex-wrap gap-2 items-end", data: { turbo: false } do %>
                    <%= hidden_field_tag :leave_type_id, lt.id %>
                    <%= number_field_tag :adjustment_hours, nil, step: 0.25, class: "tc-input w-24", placeholder: "±hrs", required: true %>
                    <%= text_field_tag :reason, nil, class: "tc-input min-w-[12rem]", placeholder: "Reason", required: true %>
                    <%= submit_tag "Apply", class: "tc-btn tc-btn--secondary" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>

  <section class="tc-panel mt-4">
    <div class="tc-panel__header"><div class="tc-panel__title">Recent adjustments</div></div>
    <div class="tc-panel__body text-sm">
      <% if @adjustments.empty? %>
        <p class="text-slate-600">No adjustments yet.</p>
      <% else %>
        <ul class="m-0 list-none space-y-2 p-0 font-mono text-xs">
          <% @adjustments.each do |adj| %>
            <li>
              <%= adj.adjusted_at.in_time_zone.to_fs(:db) %>
              · <%= adj.adjustment_hours %> hrs
              · <%= adj.reason %>
              · <%= adj.adjusted_by&.email %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </section>
</div>
