<%= render "shared/errors", model: @document_record %>
<%= form_with model: [:admin, @document_record], data: { turbo: false } do |f| %>
  <%= tc_admin_return_navigation_hidden_fields %>
  <%= hidden_field_tag :document_intake_mode, @document_intake_mode if @document_intake_mode.present? %>
  <%= hidden_field_tag :document_requirement_id, params[:document_requirement_id] if params[:document_requirement_id].present? %>
  <div class="mb-3">
    <%= f.label :document_type_id, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.collection_select :document_type_id, @document_types, :id, :name, {}, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :team_member_id, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.collection_select :team_member_id, @team_members, :id, ->(tm) { "##{tm.id} #{tm.party&.display_name}" }, { include_blank: "— optional —" }, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :engagement_id, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.collection_select :engagement_id, @engagements, :id, ->(e) { "##{e.id} #{e.relationship_type} TM #{e.team_member_id}" }, { include_blank: "— optional —" }, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :party_id, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.number_field :party_id, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :display_name, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :display_name, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :filename, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :filename, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :content_type, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :content_type, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :byte_size, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.number_field :byte_size, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :storage_key, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :storage_key, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>

  <% if @document_record.new_record? || @document_record.status == "submitted" %>
    <div class="mb-3 rounded border border-slate-200 bg-slate-50 p-3 text-xs text-slate-600 mb-4">
      New records are created as <code class="font-mono">submitted</code>. Review actions (Verify / Reject / Void) are on the record detail page — not editable here (**TC-08**).
    </div>
    <div class="mb-3">
      <%= f.label :submitted_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :submitted_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
    </div>
    <div class="mb-3">
      <%= f.label :issued_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :issued_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
    </div>
    <div class="mb-3">
      <%= f.label :expires_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :expires_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
    </div>
  <% else %>
    <div class="mb-3 rounded border border-amber-200 bg-amber-50 p-3 text-xs text-amber-900 mb-4">
      This record has left <code class="font-mono">submitted</code>. You can adjust file metadata and dates only; review status changes use Verify / Reject / Void from the detail page (<code class="font-mono">submitted_on</code> is fixed after submission pipeline).
    </div>
    <div class="mb-3">
      <%= f.label :issued_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :issued_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
    </div>
    <div class="mb-3">
      <%= f.label :expires_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :expires_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
    </div>
  <% end %>

  <%= f.submit class: "rounded bg-slate-900 text-white px-4 py-2 text-sm cursor-pointer" %>
<% end %>
