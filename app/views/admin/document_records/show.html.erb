<% content_for :title, "Document record ##{@document_record.id} — TeamCORE Admin" %>
<div class="tc-page-stack">
  <p class="text-sm flex flex-wrap gap-3">
    <%= link_to "← Document records", admin_document_records_path, class: tc_link_classes %>
    <%= link_to "Pending review", admin_document_reviews_path, class: tc_link_classes %>
  </p>

  <% if flash[:alert].present? %>
    <div class="tc-alert tc-alert--danger" role="alert"><%= flash[:alert] %></div>
  <% end %>

  <header class="tc-record-header">
    <div class="tc-record-header__top">
      <div>
        <div class="tc-record-header__eyebrow">Compliance</div>
        <h1 class="tc-record-header__title"><%= @document_record.document_type&.name.presence || "Document record" %></h1>
        <p class="tc-record-header__subtitle">
          Record #<%= @document_record.id %> · <%= @document_record.document_type&.code %>
        </p>
        <div class="tc-record-header__badges">
          <span class="<%= tc_status_badge_classes(@document_record.status) %>"><%= @document_record.status %></span>
        </div>
      </div>
      <div class="tc-record-header__actions">
        <% if @document_record.team_member %>
          <%= link_to "Team360",
                tc_team360_url(@document_record.team_member, engagement: @document_record.engagement),
                class: "tc-btn tc-btn--teal" %>
        <% end %>
        <%= link_to "Edit metadata", edit_admin_document_record_path(@document_record), class: "tc-btn tc-btn--secondary" %>
      </div>
    </div>
  </header>

  <div class="tc-record-layout">
    <section class="tc-record-main">
      <section class="tc-panel">
        <div class="tc-panel__header">
          <div>
            <div class="tc-panel__title">Review actions</div>
            <p class="tc-panel__subtitle">Readiness updates after the record saves — TC-08.</p>
          </div>
        </div>
        <div class="tc-panel__body">
          <% case @document_record.status
             when "submitted" %>
            <div class="space-y-4">
              <%= form_with url: verify_admin_document_record_path(@document_record), method: :post, data: { turbo: false }, class: "rounded-lg border p-3" do %>
                <%= tc_admin_return_navigation_hidden_fields %>
                <div class="tc-field">
                  <%= label_tag :verification_notes, "Notes (optional)", class: "tc-label" %>
                  <%= text_area_tag :verification_notes, nil, rows: 2, class: "tc-textarea" %>
                </div>
                <%= submit_tag "Verify document", data: { confirm: "Verify this submission?" }, class: "tc-btn tc-btn--teal mt-2" %>
              <% end %>

              <%= form_with url: reject_admin_document_record_path(@document_record), method: :post, data: { turbo: false }, class: "rounded-lg border p-3" do %>
                <%= tc_admin_return_navigation_hidden_fields %>
                <div class="tc-field">
                  <%= label_tag :rejection_reason, "Rejection reason (required)", class: "tc-label" %>
                  <%= text_area_tag :rejection_reason, nil, rows: 3, required: true, class: "tc-textarea" %>
                </div>
                <div class="tc-field">
                  <%= label_tag :verification_notes, "Notes (optional)", class: "tc-label" %>
                  <%= text_area_tag :verification_notes, nil, rows: 2, class: "tc-textarea" %>
                </div>
                <%= submit_tag "Reject document", data: { confirm: "Reject this submission?" }, class: "tc-btn tc-btn--danger mt-2" %>
              <% end %>

              <%= form_with url: void_admin_document_record_path(@document_record), method: :post, data: { turbo: false }, class: "rounded-lg border p-3" do %>
                <%= tc_admin_return_navigation_hidden_fields %>
                <div class="tc-field">
                  <%= label_tag :verification_notes, "Notes (optional, void context)", class: "tc-label" %>
                  <%= text_area_tag :verification_notes, nil, rows: 2, class: "tc-textarea" %>
                </div>
                <%= submit_tag "Void submission", data: { confirm: "Void this record? It will not count toward readiness." }, class: "tc-btn tc-btn--secondary mt-2" %>
              <% end %>
            </div>
          <% when "verified", "rejected" %>
            <%= form_with url: void_admin_document_record_path(@document_record), method: :post, data: { turbo: false }, class: "max-w-xl rounded-lg border p-3" do %>
              <%= tc_admin_return_navigation_hidden_fields %>
              <div class="tc-field">
                <%= label_tag :verification_notes, "Notes (optional, void context)", class: "tc-label" %>
                <%= text_area_tag :verification_notes, nil, rows: 2, class: "tc-textarea" %>
              </div>
              <%= submit_tag "Void record", data: { confirm: "Void this record? Prior review metadata is preserved." }, class: "tc-btn tc-btn--secondary mt-2" %>
            <% end %>
          <% else %>
            <p class="text-sm" style="color: var(--tc-text-muted);">No further review actions (<code class="font-mono">voided</code> is terminal in MVP).</p>
          <% end %>
        </div>
      </section>
    </section>

    <aside class="tc-record-context tc-record-context--sticky">
      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Record details</div>
        </div>
        <div class="tc-panel__body">
          <dl class="tc-kv-grid tc-kv-grid--single">
            <div class="tc-kv">
              <dt class="tc-kv__key">Team member</dt>
              <dd class="tc-kv__value">
                <%= @document_record.team_member_id %>
                <%= @document_record.team_member&.party&.display_name %>
              </dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Engagement</dt>
              <dd class="tc-kv__value font-mono text-xs"><%= @document_record.engagement_id || "—" %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Submitted</dt>
              <dd class="tc-kv__value font-mono text-xs"><%= @document_record.submitted_on %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Expires</dt>
              <dd class="tc-kv__value font-mono text-xs"><%= @document_record.expires_on || "—" %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Verified by</dt>
              <dd class="tc-kv__value"><%= @document_record.verified_by_id ? @document_record.verified_by&.email : "—" %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Verified on</dt>
              <dd class="tc-kv__value font-mono text-xs"><%= @document_record.verified_on || "—" %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Verification notes</dt>
              <dd class="tc-kv__value"><%= @document_record.verification_notes.presence || "—" %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Rejection reason</dt>
              <dd class="tc-kv__value"><%= @document_record.rejection_reason.presence || "—" %></dd>
            </div>
          </dl>
        </div>
      </section>
    </aside>
  </div>
</div>
