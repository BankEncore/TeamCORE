<% content_for :title, "Document records — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Compliance</p>
      <h1 class="tc-page-header__title">Document records</h1>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "New record", new_admin_document_record_path, class: "tc-btn tc-btn--primary" %>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Type</th>
          <th>Status</th>
          <th>Engagement</th>
          <th>Team member</th>
        </tr>
      </thead>
      <tbody>
        <% @document_records.each do |rec| %>
          <tr>
            <td class="tc-data-table__primary font-mono"><%= link_to rec.id, admin_document_record_path(rec), class: tc_link_classes %></td>
            <td class="tc-data-table__cell-muted font-mono text-xs"><%= rec.document_type&.code %></td>
            <td><span class="<%= tc_status_badge_classes(rec.status) %>"><%= rec.status %></span></td>
            <td class="font-mono text-xs"><%= rec.engagement_id || "—" %></td>
            <td class="font-mono text-xs"><%= rec.team_member_id %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
