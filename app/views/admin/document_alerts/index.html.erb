<% content_for :title, "Document alerts" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Compliance queue</p>
      <h1 class="tc-page-header__title">Document alerts</h1>
      <p class="tc-page-header__subtitle">
        Exception list across engagements (virtual, read-time). Default scope excludes terminal engagements
        (<code class="font-mono text-xs">ended</code>, <code class="font-mono text-xs">terminated</code>, <code class="font-mono text-xs">cancelled</code>).
        Use <span class="font-mono text-xs">include_terminal</span> to include them.
      </p>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "Dashboard", admin_root_path, class: "#{tc_link_classes} text-sm" %>
    </div>
  </header>

  <%= form_with url: admin_document_alerts_path, method: :get, data: { turbo: false }, class: "tc-form-section tc-form-section--dense" do %>
    <div class="tc-form-section__header">
      <h2 class="tc-form-section__title">Filters</h2>
    </div>
    <div class="tc-form-grid tc-form-grid--dense">
      <div class="tc-field tc-field--compact">
        <%= label_tag :as_of_date, "As of date (ISO)", class: "tc-label" %>
        <%= text_field_tag :as_of_date, params[:as_of_date].presence || @as_of_date.iso8601, class: "tc-input" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :alert_type, "Alert type", class: "tc-label" %>
        <%= select_tag :alert_type,
              options_for_select(
                [
                  [ "— any —", "" ],
                  %w[missing missing],
                  %w[expired expired],
                  %w[expiring_soon expiring_soon],
                  %w[rejected rejected],
                  %w[pending_verification pending_verification]
                ],
                params[:alert_type]
              ),
              class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :severity, "Severity", class: "tc-label" %>
        <%= select_tag :severity,
              options_for_select(
                [
                  [ "— any —", "" ],
                  %w[blocking blocking],
                  %w[warning warning],
                  %w[info info]
                ],
                params[:severity]
              ),
              class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :relationship_type, "Relationship type", class: "tc-label" %>
        <%= select_tag :relationship_type,
              options_for_select(
                [ [ "— any —", "" ] ] + Engagement::RELATIONSHIP_TYPES.map { |rt| [ rt, rt ] },
                params[:relationship_type]
              ),
              class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :engagement_status, "Engagement status", class: "tc-label" %>
        <%= select_tag :engagement_status,
              options_for_select(
                [ [ "— any —", "" ] ] + Engagement::STATUSES.map { |s| [ s, s ] },
                params[:engagement_status]
              ),
              class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :document_type_id, "Document type id", class: "tc-label" %>
        <%= text_field_tag :document_type_id, params[:document_type_id], class: "tc-input", placeholder: "numeric id" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :team_member_id, "Team member id", class: "tc-label" %>
        <%= text_field_tag :team_member_id, params[:team_member_id], class: "tc-input", placeholder: "numeric id" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :expires_on_or_before, "Expires on or before (ISO)", class: "tc-label" %>
        <%= text_field_tag :expires_on_or_before, params[:expires_on_or_before], class: "tc-input" %>
      </div>
      <div class="tc-field tc-field--compact flex items-end">
        <label class="flex items-center gap-2 text-sm" style="color: var(--tc-text);">
          <%= check_box_tag :include_terminal, "1", params[:include_terminal].present? %>
          Include terminal engagements
        </label>
      </div>
    </div>
    <div class="mt-3 flex flex-wrap gap-2 border-t pt-3" style="border-color: var(--tc-border);">
      <%= submit_tag "Apply filters", class: "tc-btn tc-btn--primary" %>
      <%= link_to "Reset", admin_document_alerts_path, class: "tc-btn tc-btn--secondary" %>
    </div>
  <% end %>

  <% if @flat_alert_rows.empty? %>
    <p class="text-sm" style="color: var(--tc-text-muted);">No alerts match the current filters.</p>
  <% else %>
    <div class="tc-table-wrap">
      <table class="tc-data-table tc-data-table--compact text-xs">
        <thead>
          <tr>
            <th>Team member</th>
            <th>Engagement</th>
            <th>Relationship</th>
            <th>Severity</th>
            <th>Type</th>
            <th>Message</th>
            <th>Requirement</th>
            <th>Doc type</th>
            <th>Record</th>
            <th>Expires</th>
          </tr>
        </thead>
        <tbody>
          <% @flat_alert_rows.each do |row| %>
            <% eg = row.engagement %>
            <% alert = row.alert %>
            <% dtype = @document_types_by_id[alert.document_type_id] %>
            <tr>
              <td class="tc-data-table__primary">
                <%= link_to eg.team_member.party.display_name, admin_team_member_path(eg.team_member), class: tc_link_classes %>
              </td>
              <td><%= link_to "##{eg.id}", admin_engagement_path(eg), class: "#{tc_link_classes} font-mono" %></td>
              <td class="font-mono"><%= eg.relationship_type %></td>
              <td><span class="<%= tc_status_badge_classes(alert.severity) %>"><%= alert.severity %></span></td>
              <td class="font-mono"><%= alert.alert_type %></td>
              <td class="tc-data-table__cell-wrap text-xs"><%= alert.message %></td>
              <td><%= link_to "Req ##{alert.document_requirement_id}", edit_admin_document_requirement_path(alert.document_requirement_id), class: tc_link_classes %></td>
              <td>
                <% if dtype %>
                  <%= link_to dtype.code, admin_document_type_path(dtype), class: tc_link_classes %>
                <% else %>
                  <span class="font-mono tc-data-table__cell-muted">#<%= alert.document_type_id %></span>
                <% end %>
              </td>
              <td>
                <% if alert.document_record_id.present? %>
                  <%= link_to "##{alert.document_record_id}", admin_document_record_path(alert.document_record_id), class: "#{tc_link_classes} font-mono" %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="font-mono tc-data-table__cell-muted"><%= alert.expires_on&.iso8601 || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
