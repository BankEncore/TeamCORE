<% content_for :title, "Operational reports" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Reports</p>
      <h1 class="tc-page-header__title">Operational reports</h1>
      <p class="tc-page-header__subtitle">
        Dense admin hub (TC-12). Each report queries authoritative models and evaluator output — no snapshot tables.
      </p>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "Dashboard", admin_root_path, class: "#{tc_link_classes} text-sm" %>
    </div>
  </header>

  <div class="tc-panel divide-y p-0" style="border-color: var(--tc-border);">
    <%= link_to admin_reports_team_members_path, class: "tc-report-hub-card" do %>
      <span class="font-medium" style="color: var(--tc-primary);">Team member roster</span>
      <p class="mt-1 text-sm" style="color: var(--tc-text-muted);">Filters on party type, TM status, engagement dimensions, placement, supervisor, readiness.</p>
    <% end %>
    <%= link_to admin_reports_engagements_path, class: "tc-report-hub-card" do %>
      <span class="font-medium" style="color: var(--tc-primary);">Engagement roster</span>
      <p class="mt-1 text-sm" style="color: var(--tc-text-muted);">Relationship type, status, dates, placement, supervisor — links to Team360 and engagement.</p>
    <% end %>
    <%= link_to admin_reports_document_compliance_index_path, class: "tc-report-hub-card" do %>
      <span class="font-medium" style="color: var(--tc-primary);">Document compliance exceptions</span>
      <p class="mt-1 text-sm" style="color: var(--tc-text-muted);">Virtual alerts from <code class="font-mono text-xs">ReadinessEvaluator</code>; drill-through to records and Team360.</p>
    <% end %>
    <%= link_to admin_reports_contractor_documentation_index_path, class: "tc-report-hub-card" do %>
      <span class="font-medium" style="color: var(--tc-primary);">Contractor documentation exceptions</span>
      <p class="mt-1 text-sm" style="color: var(--tc-text-muted);">Contractor-class engagements only; optional document category filter (type <code class="font-mono text-xs">category</code>).</p>
    <% end %>
    <%= link_to admin_reports_subcontractors_path, class: "tc-report-hub-card" do %>
      <span class="font-medium" style="color: var(--tc-primary);">Subcontractor relationships</span>
      <p class="mt-1 text-sm" style="color: var(--tc-text-muted);">Incoming subcontractor PartyRelationship rows; promoted targets link to Team360.</p>
    <% end %>
  </div>
</div>
