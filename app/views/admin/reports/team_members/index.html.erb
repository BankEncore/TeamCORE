<% content_for :title, "Report — Team member roster" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Reports</p>
      <h1 class="tc-page-header__title">Team member roster</h1>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "Reports hub", admin_reports_root_path, class: "#{tc_link_classes} text-sm" %>
    </div>
  </header>

  <%= form_with url: admin_reports_team_members_path, method: :get, data: { turbo: false }, class: "tc-form-section tc-form-section--dense mb-6" do %>
    <div class="tc-form-section__header">
      <h2 class="tc-form-section__title">Filters</h2>
    </div>
    <div class="tc-form-grid tc-form-grid--dense">
      <div class="tc-field tc-field--compact">
        <%= label_tag :as_of_date, "As of (ISO)", class: "tc-label" %>
        <%= date_field_tag :as_of_date, @as_of_date, class: "tc-input" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :party_type, "Party type", class: "tc-label" %>
        <%= select_tag :party_type, options_for_select([["— any —", ""]] + Party::PARTY_TYPES.zip(Party::PARTY_TYPES), params[:party_type]), class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :team_member_status, "Team member status", class: "tc-label" %>
        <%= select_tag :team_member_status, options_for_select([["— any —", ""]] + LifecycleStatusable::STATUSES.zip(LifecycleStatusable::STATUSES), params[:team_member_status]), class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :engagement_relationship_type, "Has engagement type", class: "tc-label" %>
        <%= select_tag :engagement_relationship_type, options_for_select([["— any —", ""]] + Engagement::RELATIONSHIP_TYPES.zip(Engagement::RELATIONSHIP_TYPES), params[:engagement_relationship_type]), class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :engagement_status, "Has engagement status", class: "tc-label" %>
        <%= select_tag :engagement_status, options_for_select([["— any —", ""]] + Engagement::STATUSES.zip(Engagement::STATUSES), params[:engagement_status]), class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :department_id, "Dept id (effective placement)", class: "tc-label" %>
        <%= text_field_tag :department_id, params[:department_id], class: "tc-input" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :location_id, "Location id", class: "tc-label" %>
        <%= text_field_tag :location_id, params[:location_id], class: "tc-input" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :team_id, "Team id", class: "tc-label" %>
        <%= text_field_tag :team_id, params[:team_id], class: "tc-input" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :supervisor_engagement_id, "Supervisor engagement id", class: "tc-label" %>
        <%= text_field_tag :supervisor_engagement_id, params[:supervisor_engagement_id], class: "tc-input" %>
      </div>
      <div class="tc-field tc-field--compact">
        <%= label_tag :document_readiness_status, "Readiness (focused eng.)", class: "tc-label" %>
        <%= select_tag :document_readiness_status,
              options_for_select([["— any —", ""]] + Documents::ReadinessEvaluator::READINESS_STATUSES.zip(Documents::ReadinessEvaluator::READINESS_STATUSES), params[:document_readiness_status]),
              class: "tc-select" %>
      </div>
      <div class="tc-field tc-field--compact flex items-end">
        <%= submit_tag "Apply", class: "tc-btn tc-btn--primary" %>
      </div>
    </div>
  <% end %>

  <div class="tc-table-wrap">
    <table class="tc-data-table tc-data-table--compact text-sm">
      <thead>
        <tr>
          <th>Name</th>
          <th>Party type</th>
          <th>TM #</th>
          <th>TM status</th>
          <th>Focused engagement</th>
          <th>Readiness</th>
          <th>Alerts</th>
          <th>Team360</th>
        </tr>
      </thead>
      <tbody>
        <% @roster_rows.each do |row| %>
          <% tm = row[:team_member] %>
          <tr>
            <td class="tc-data-table__primary"><%= row[:display_name] %></td>
            <td class="font-mono text-xs tc-data-table__cell-muted"><%= row[:party_type] %></td>
            <td class="font-mono"><%= tm.team_member_number.presence || tm.id %></td>
            <td><span class="<%= tc_status_badge_classes(tm.status) %>"><%= tm.status %></span></td>
            <td class="text-xs"><%= row[:engagement_summary] %></td>
            <td>
              <% if row[:readiness_status].present? %>
                <span class="<%= tc_readiness_badge_classes(row[:readiness_status]) %>"><%= row[:readiness_status] %></span>
              <% else %>
                —
              <% end %>
            </td>
            <td><%= row[:alert_count] %></td>
            <td><%= link_to "Open", reports_team360_path(tm, engagement: row[:focused_engagement]), class: tc_link_classes %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
