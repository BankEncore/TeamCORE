<% content_for :title, "Onboarding — #{current_agency.name}" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Workspace</p>
      <h1 class="tc-page-header__title">Onboarding</h1>
      <p class="tc-page-header__subtitle">
        Workspace entry for onboarding; flows still run on <%= link_to "/admin/guided", admin_guided_setup_path, class: tc_link_classes %> (not replaced).
      </p>
    </div>
  </header>

  <div class="tc-panel">
    <div class="tc-panel__header">
      <div class="tc-panel__title">Guided flows</div>
    </div>
    <div class="tc-panel__body text-sm space-y-2">
      <ul class="m-0 list-none space-y-2 p-0">
        <li><%= link_to "Guided hub", admin_guided_setup_path, class: tc_link_classes %></li>
        <li><%= link_to "Employee", admin_guided_employee_path, class: tc_link_classes %></li>
        <li><%= link_to "Individual contractor", admin_guided_individual_contractor_path, class: tc_link_classes %></li>
        <li><%= link_to "Contractor organization", admin_guided_contractor_organization_path, class: tc_link_classes %></li>
        <li><%= link_to "Subcontractor", admin_guided_subcontractor_path, class: tc_link_classes %></li>
      </ul>
    </div>
  </div>
</div>
