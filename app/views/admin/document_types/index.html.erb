<% content_for :title, "Document types — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">Setup</p>
      <h1 class="tc-page-header__title">Document types</h1>
    </div>
    <div class="tc-page-header__actions">
      <%= link_to "New document type", new_admin_document_type_path, class: "tc-btn tc-btn--primary" %>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>Category</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @document_types.each do |dt| %>
          <tr>
            <td class="tc-data-table__primary"><%= link_to dt.code, admin_document_type_path(dt), class: tc_link_classes %></td>
            <td><%= dt.name %></td>
            <td class="tc-data-table__cell-muted"><%= dt.category %></td>
            <td><span class="<%= tc_status_badge_classes(dt.status) %>"><%= dt.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
