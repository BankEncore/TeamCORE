<%= form_with model: [:admin, compensation_plan], class: "space-y-4 max-w-xl" do |f| %>
  <% if compensation_plan.errors.any? %>
    <div class="text-red-600 text-sm"><%= compensation_plan.errors.full_messages.join(", ") %></div>
  <% end %>
  <div class="tc-field">
    <%= f.label :name, class: "tc-label" %>
    <%= f.text_field :name, class: "tc-input" %>
  </div>
  <div class="tc-field">
    <%= f.label :plan_type, class: "tc-label" %>
    <%= f.select :plan_type,
          options_for_select(CompensationPlan::PLAN_TYPES.map { |t| [ t.humanize, t ] }, compensation_plan.plan_type),
          {},
          class: "tc-select" %>
  </div>
  <div class="tc-field">
    <%= f.label :status, class: "tc-label" %>
    <%= f.select :status,
          options_for_select(CompensationPlan::STATUSES.map { |s| [ s.humanize, s ] }, compensation_plan.status),
          {},
          class: "tc-select" %>
  </div>
  <div class="tc-field">
    <%= f.label :default_commission_rate_percent, "Commission rate", class: "tc-label" %>
    <%= f.text_field :default_commission_rate_percent, class: "tc-input", placeholder: "10.00", inputmode: "decimal", autocomplete: "off" %>
    <p class="text-xs text-slate-500">Enter as a percent (e.g. <strong><%= tc_percent_from_bps(1000) %></strong> — you may include a % sign).</p>
  </div>
  <div class="tc-field">
    <%= f.label :minimum_commission_amount_money, "Minimum gross commission (employee draw)", class: "tc-label" %>
    <%= f.text_field :minimum_commission_amount_money, class: "tc-input", placeholder: "0.00", inputmode: "decimal", autocomplete: "off" %>
    <p class="text-xs text-slate-500">Enter dollars (e.g. <%= number_to_currency(2000) %> for a $2,000 minimum).</p>
  </div>
  <div class="tc-field">
    <%= f.label :minimum_commission_basis, class: "tc-label" %>
    <%= f.select :minimum_commission_basis,
          options_for_select(
            CompensationPlan.minimum_basis_select_values(compensation_plan.minimum_commission_basis).map { |b| [ b.humanize, b ] },
            compensation_plan.minimum_commission_basis
          ),
          { include_blank: "—" },
          class: "tc-select" %>
  </div>
  <div class="tc-field">
    <%= f.label :recovery_rule, class: "tc-label" %>
    <%= f.select :recovery_rule,
          options_for_select(
            CompensationPlan.recovery_rule_select_values(compensation_plan.recovery_rule).map { |r| [ r.humanize, r ] },
            compensation_plan.recovery_rule
          ),
          { include_blank: "—" },
          class: "tc-select" %>
  </div>
  <div class="tc-field">
    <%= f.label :salary_annual_money, "Annual salary", class: "tc-label" %>
    <%= f.text_field :salary_annual_money, class: "tc-input", placeholder: "0.00", inputmode: "decimal", autocomplete: "off" %>
  </div>
  <div class="tc-field">
    <%= f.label :hourly_rate_money, "Hourly rate", class: "tc-label" %>
    <%= f.text_field :hourly_rate_money, class: "tc-input", placeholder: "0.00", inputmode: "decimal", autocomplete: "off" %>
  </div>
  <%= f.submit class: "tc-btn tc-btn--primary" %>
<% end %>
