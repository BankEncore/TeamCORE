<% content_for :title, "Parties — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">People</p>
      <h1 class="tc-page-header__title">Parties</h1>
      <p class="tc-page-header__subtitle">People and organizations that can be linked to team memberships.</p>
    </div>
    <div class="tc-page-header__actions">
      <div class="tc-action-bar">
        <%= link_to "New person", admin_new_person_party_path, class: "tc-btn tc-btn--primary" %>
        <%= link_to "New organization", admin_new_organization_party_path, class: "tc-btn tc-btn--secondary" %>
      </div>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table">
      <thead>
        <tr>
          <th>Display</th>
          <th>Type</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @parties.each do |p| %>
          <tr>
            <td class="tc-data-table__primary"><%= link_to(p.display_name.presence || "Party ##{p.id}", admin_party_path(p), class: tc_link_classes) %></td>
            <td class="tc-data-table__cell-muted"><%= p.party_type %></td>
            <td><span class="<%= tc_status_badge_classes(p.status) %>"><%= p.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
