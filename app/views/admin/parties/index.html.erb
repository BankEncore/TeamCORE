<% content_for :title, "Parties — TeamCORE Admin" %>
<div class="flex flex-wrap gap-3 justify-between items-center mb-4">
  <h1 class="text-2xl font-semibold">Parties</h1>
  <div class="flex gap-2">
    <%= link_to "New person", admin_new_person_party_path, class: "rounded bg-slate-900 text-white px-3 py-2 text-sm" %>
    <%= link_to "New organization", admin_new_organization_party_path, class: "rounded bg-slate-700 text-white px-3 py-2 text-sm" %>
  </div>
</div>
<table class="min-w-full text-sm border border-slate-200 bg-white rounded-lg overflow-hidden">
  <thead class="bg-slate-100">
    <tr><th class="text-left p-2">Display</th><th class="text-left p-2">Type</th><th class="text-left p-2">Status</th></tr>
  </thead>
  <tbody>
    <% @parties.each do |p| %>
      <tr class="border-t border-slate-200">
        <td class="p-2"><%= link_to (p.display_name.presence || "Party ##{p.id}"), admin_party_path(p), class: "text-sky-700 underline" %></td>
        <td class="p-2"><%= p.party_type %></td>
        <td class="p-2"><%= p.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>
