<%# locals: f (form builder), status_mode: :full | :advanced %>
<div class="mb-4 rounded border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
  A Party is a person or organization identity record.
  Create a <strong>Team member</strong> when this party participates in agency workforce operations (engagements, documents, Team360, settlement).
</div>

<div class="mb-3">
  <%= f.label :display_name, class: "block text-sm font-medium text-slate-700 mb-1" %>
  <%= f.text_field :display_name, class: "w-full border border-slate-300 rounded px-3 py-2" %>
</div>
<div class="mb-3">
  <%= f.label :external_reference, class: "block text-sm font-medium text-slate-700 mb-1" %>
  <%= f.text_field :external_reference, class: "w-full border border-slate-300 rounded px-3 py-2" %>
</div>
<div class="mb-3">
  <%= f.label :notes, class: "block text-sm font-medium text-slate-700 mb-1" %>
  <%= f.text_area :notes, rows: 2, class: "w-full border border-slate-300 rounded px-3 py-2" %>
</div>

<% status_opts = LifecycleStatusable::STATUSES.map { |s| [ s.humanize, s ] } %>
<% if status_mode == :full %>
  <div class="mb-4">
    <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :status, status_opts, {}, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
<% elsif status_mode == :advanced %>
  <details class="mb-4 rounded border border-slate-200 p-3">
    <summary class="cursor-pointer text-sm font-medium text-slate-800">Advanced options</summary>
    <p class="text-xs text-slate-500 mt-2 mb-2">Status defaults to <strong>active</strong>. Change only if you intend a non-active identity record.</p>
    <div class="mb-0">
      <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :status, status_opts, {}, class: "w-full border border-slate-300 rounded px-3 py-2" %>
    </div>
  </details>
<% end %>
