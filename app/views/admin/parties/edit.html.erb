<% content_for :title, "Edit party — TeamCORE Admin" %>
<h1 class="text-2xl font-semibold mb-4">Edit party</h1>
<%= render "shared/errors", model: @party %>
<%= form_with model: [:admin, @party], data: { turbo: false } do |f| %>
  <%= render "admin/parties/party_basics_fields", f: f, status_mode: :full %>

  <% if @party.person? %>
    <%= f.fields_for :person_profile do |pf| %>
      <%= pf.hidden_field :id if pf.object.persisted? %>
      <%= render "admin/parties/person_profile_fields", pf: pf %>
    <% end %>
  <% else %>
    <%= f.fields_for :organization_profile do |of| %>
      <%= of.hidden_field :id if of.object.persisted? %>
      <%= render "admin/parties/organization_profile_fields", of: of %>
    <% end %>
  <% end %>

  <%= f.submit "Save", class: "mt-4 rounded bg-slate-900 text-white px-4 py-2 text-sm cursor-pointer" %>
<% end %>
