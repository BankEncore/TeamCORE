<% content_for :title, "New organization party — TeamCORE Admin" %>
<h1 class="text-2xl font-semibold mb-4">New organization party</h1>
<%= render "shared/errors", model: @party %>
<%= form_with model: @party, url: admin_organization_parties_path, method: :post, data: { turbo: false } do |f| %>
  <%= render "admin/parties/party_basics_fields", f: f, status_mode: :advanced %>
  <%= fields_for "party[organization_profile]", @party.organization_profile do |of| %>
    <%= render "admin/parties/organization_profile_fields", of: of %>
  <% end %>
  <%= f.submit "Create party", class: "mt-4 rounded bg-slate-900 text-white px-4 py-2 text-sm cursor-pointer" %>
<% end %>
