<%= form_with model: [:admin, @code], data: { turbo: false } do |f| %>
  <% if @code.errors.any? %>
    <div class="text-red-700 text-sm mb-4">
      <%= @code.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div class="tc-field">
    <%= f.label :code, class: "tc-label" %>
    <%= f.text_field :code, class: "tc-input" %>
  </div>
  <div class="tc-field">
    <%= f.label :name, class: "tc-label" %>
    <%= f.text_field :name, class: "tc-input" %>
  </div>
  <div class="tc-field">
    <%= f.label :direction, class: "tc-label" %>
    <%= f.select :direction, PayrollAdjustmentCode::DIRECTIONS, {}, class: "tc-select" %>
  </div>
  <div class="tc-field">
    <label class="flex items-center gap-2 text-sm">
      <%= f.check_box :active %>
      Active
    </label>
  </div>
  <%= f.submit class: "tc-btn tc-btn--primary" %>
<% end %>
