<%# @snapshot, @as_of_date, @team_member (instance variables) %>
<% content_for :title, "Team360 — #{@snapshot.identity[:display_name]}" %>
<div class="tc-page-stack">
  <div class="mb-2">
    <%= link_to "← Team member", admin_team_member_path(@team_member), class: "text-sm #{tc_link_classes}" %>
  </div>

  <header class="tc-record-header">
    <div class="tc-record-header__top">
      <div>
        <div class="tc-record-header__eyebrow">Team360</div>
        <h1 class="tc-record-header__title"><%= @snapshot.identity[:display_name] %></h1>
        <p class="tc-record-header__subtitle">
          Party <%= @snapshot.identity[:party_type] %> · TM #<%= @snapshot.identity[:team_member_id] %>
          <% if @snapshot.identity[:team_member_number].present? %>
            · <%= @snapshot.identity[:team_member_number] %>
          <% end %>
          · status
          <span class="<%= tc_status_badge_classes(@snapshot.identity[:team_member_status]) %>"><%= @snapshot.identity[:team_member_status] %></span>
        </p>
        <div class="tc-record-header__badges">
          <span class="tc-badge tc-badge--neutral">As of <%= @as_of_date.iso8601 %></span>
          <% if @snapshot.readiness_result %>
            <span class="<%= tc_readiness_badge_classes(@snapshot.readiness_result.readiness_status) %>">
              Readiness: <%= @snapshot.readiness_result.readiness_status %>
            </span>
          <% end %>
        </div>
      </div>
      <div class="tc-record-header__actions">
        <%= form_with url: admin_team_member_team360_path(@team_member), method: :get, data: { turbo: false }, class: "flex flex-wrap gap-2 items-end text-sm" do %>
          <% if params[:engagement_id].present? %>
            <%= hidden_field_tag :engagement_id, params[:engagement_id] %>
          <% end %>
          <%= label_tag :as_of_date, "As of", class: "text-white/80 text-xs block w-full" %>
          <%= date_field_tag :as_of_date, @as_of_date, class: "rounded border border-white/30 bg-white/10 text-white px-2 py-1 text-sm" %>
          <%= submit_tag "Apply", class: "tc-btn tc-btn--secondary" %>
        <% end %>
      </div>
    </div>
  </header>

  <% if @snapshot.engagement_summaries.size > 1 %>
    <div class="tc-panel">
      <div class="tc-panel__header">
        <div>
          <div class="tc-panel__title">Focused engagement</div>
          <p class="tc-panel__subtitle">Display selection for organization and document panels (TC-3-D03).</p>
        </div>
      </div>
        <div class="tc-panel__body">
          <%= form_with url: admin_team_member_team360_path(@team_member), method: :get, data: { turbo: false }, class: "flex flex-wrap items-end gap-3" do %>
            <%= hidden_field_tag :as_of_date, @as_of_date.iso8601 %>
            <div class="tc-field tc-field--compact min-w-[12rem]">
              <%= label_tag :engagement_id, "Engagement", class: "tc-label" %>
              <%= select_tag :engagement_id,
                    options_for_select(
                      @snapshot.engagement_summaries.map { |s|
                        [ "##{s[:id]} #{s[:relationship_type]} — #{s[:status]}", s[:id] ]
                      },
                      @snapshot.focused_engagement_id
                    ),
                    class: "tc-select" %>
            </div>
            <%= submit_tag "Update focus", class: "tc-btn tc-btn--primary" %>
          <% end %>
        </div>
    </div>
  <% end %>

  <div class="tc-record-layout">
    <div class="tc-record-main tc-team360">
      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Identity</div>
        </div>
        <div class="tc-panel__body">
          <dl class="tc-kv-grid">
            <dt>Party</dt>
            <dd>
              <%= link_to "Party ##{@snapshot.identity[:party_id]}", admin_party_path(@snapshot.identity[:party_id]), class: tc_link_classes %>
            </dd>
            <dt>Display name</dt>
            <dd><%= @snapshot.identity[:display_name] %></dd>
            <dt>Party type</dt>
            <dd class="font-mono"><%= @snapshot.identity[:party_type] %></dd>
            <dt>Team member #</dt>
            <dd><%= @snapshot.identity[:team_member_id] %></dd>
            <dt>TM number</dt>
            <dd><%= @snapshot.identity[:team_member_number].presence || "—" %></dd>
            <dt>TM status</dt>
            <dd class="font-mono"><%= @snapshot.identity[:team_member_status] %></dd>
          </dl>
        </div>
      </section>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Contacts</div>
        </div>
        <div class="tc-panel__body">
          <% if @snapshot.contacts.blank? %>
            <p class="text-sm text-slate-600">No party contact methods on file.</p>
          <% else %>
            <ul class="text-sm space-y-2">
              <% @snapshot.contacts.each do |c| %>
                <li>
                  <span class="font-mono text-xs text-slate-500"><%= c[:contact_type] %></span>
                  <%= c[:value] %>
                  <% if c[:is_primary] %>· primary<% end %>
                  · <span class="font-mono"><%= c[:status] %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Engagements</div>
        </div>
        <div class="tc-panel__body">
          <div class="tc-table-wrap">
            <table class="tc-data-table tc-data-table--compact text-sm">
            <thead>
              <tr>
                <th>ID</th>
                <th>Type</th>
                <th>Status</th>
                <th>Title</th>
                <th>Dates</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @snapshot.engagement_summaries.each do |s| %>
                <tr>
                  <td class="font-mono"><%= s[:id] %></td>
                  <td class="font-mono"><%= s[:relationship_type] %></td>
                  <td>
                    <% eng_badge =
                         if s[:suspended]
                           "tc-badge tc-badge--pending"
                         elsif s[:terminal]
                           "tc-badge tc-badge--neutral"
                         else
                           "tc-badge tc-badge--active"
                         end %>
                    <span class="<%= eng_badge %>"><%= s[:status] %></span>
                  </td>
                  <td><%= s[:title].presence || "—" %></td>
                  <td class="font-mono text-xs">
                    <%= s[:start_on] %> / <%= s[:end_on] || "—" %>
                    <% if s[:expected_end_on] %><br/>exp <%= s[:expected_end_on] %><% end %>
                  </td>
                  <td>
                    <%= link_to "Open", admin_engagement_path(s[:id], return_to: request.fullpath, team360_return_to: request.fullpath), class: "#{tc_link_classes} text-xs" %>
                    <% if @snapshot.focused_engagement_id == s[:id] %>
                      <span class="text-xs text-slate-500">· focus</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
          </div>
        </div>
      </section>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div>
            <div class="tc-panel__title">Organization context</div>
            <% if @snapshot.focused_engagement_id %>
              <p class="tc-panel__subtitle">From engagement <%= @snapshot.focused_engagement_id %> · effective rows for <%= @as_of_date.iso8601 %>.</p>
            <% end %>
          </div>
        </div>
        <div class="tc-panel__body">
          <% oc = @snapshot.organization_context %>
          <% if oc.blank? %>
            <p class="text-sm text-slate-600">No focused engagement.</p>
          <% else %>
            <dl class="tc-kv-grid text-sm">
              <dt>Department</dt>
              <dd>
                <% if oc[:department] %>
                  <%= oc[:department][:name] %>
                  <span class="font-mono text-xs text-slate-500">(<%= oc[:department][:status] %>)</span>
                <% else %>—<% end %>
              </dd>
              <dt>Location</dt>
              <dd>
                <% if oc[:location] %>
                  <%= oc[:location][:name] %>
                  <span class="font-mono text-xs text-slate-500">(<%= oc[:location][:status] %>)</span>
                <% else %>—<% end %>
              </dd>
              <dt>Team</dt>
              <dd>
                <% if oc[:team] %>
                  <%= oc[:team][:name] %>
                  <span class="font-mono text-xs text-slate-500">(<%= oc[:team][:status] %>)</span>
                <% else %>—<% end %>
              </dd>
              <dt>Placement effective</dt>
              <dd class="font-mono text-xs">
                <% if oc[:placement_effective] %>
                  <%= oc[:placement_effective][:start_on] %> — <%= oc[:placement_effective][:end_on] || "—" %>
                <% else %>—<% end %>
              </dd>
              <dt>Supervisor</dt>
              <dd>
                <% if oc[:supervision] %>
                  <%= oc[:supervision][:supervisor_display] || "Engagement ##{oc[:supervision][:supervisor_engagement_id]}" %>
                  <span class="font-mono text-xs text-slate-500">
                    · <%= oc[:supervision][:relationship_type] %>
                    · <%= oc[:supervision][:start_on] %> — <%= oc[:supervision][:end_on] || "—" %>
                  </span>
                <% else %>—<% end %>
              </dd>
            </dl>
            <p class="mt-3 text-xs text-slate-500">
              <%= link_to "Engagement ##{oc[:engagement_id]}", admin_engagement_path(oc[:engagement_id], return_to: request.fullpath, team360_return_to: request.fullpath), class: tc_link_classes %>
            </p>
          <% end %>
        </div>
      </section>

      <% if @engagement_setup_checklist.present? %>
        <%= render "admin/engagements/setup_checklist", presenter: @engagement_setup_checklist %>
      <% end %>

      <% if @snapshot.readiness_result %>
        <%= render partial: "admin/engagements/document_alerts",
              locals: { readiness: @snapshot.readiness_result, document_types_by_id: @snapshot.document_types_by_id } %>

        <section class="tc-panel">
          <div class="tc-panel__header">
            <div class="tc-panel__title">Document readiness summary</div>
            <p class="tc-panel__subtitle">Counts from <code class="font-mono text-xs">ReadinessResult</code> only.</p>
          </div>
          <div class="tc-panel__body">
            <% req = @snapshot.readiness_result.requirements %>
            <% counts = req.group_by(&:requirement_outcome).transform_values(&:size) %>
            <div class="tc-team360__metric-row">
              <% %w[missing pending_verification satisfied rejected expired expiring_soon not_applicable].each do |k| %>
                <div class="tc-team360__metric">
                  <div class="tc-team360__metric-value"><%= counts[k] || 0 %></div>
                  <div class="tc-team360__metric-label"><%= k %></div>
                </div>
              <% end %>
            </div>
          </div>
        </section>

        <section class="tc-panel">
          <div class="tc-panel__header">
            <div class="tc-panel__title">Verification summary</div>
            <p class="tc-panel__subtitle">Outcomes from evaluator rows; record columns are display-only (TC-3-D09).</p>
          </div>
          <div class="tc-panel__body">
            <div class="tc-table-wrap">
            <table class="tc-data-table tc-data-table--compact text-xs">
              <thead>
                <tr>
                  <th>Req</th>
                  <th>Outcome</th>
                  <th>Record status</th>
                  <th>Record</th>
                  <th>Verifier / dates</th>
                  <th>Rejection</th>
                </tr>
              </thead>
              <tbody>
                <% @snapshot.readiness_result.requirements.each do |row| %>
                  <% rec = row.document_record_id ? @snapshot.records_by_id[row.document_record_id] : nil %>
                  <tr>
                    <td class="font-mono"><%= row.document_requirement_id %></td>
                    <td class="font-mono"><%= row.requirement_outcome %></td>
                    <td class="font-mono"><%= row.record_review_status || "—" %></td>
                    <td>
                      <% if rec %>
                        <%= link_to "Record ##{rec.id}", admin_document_record_path(rec, return_to: request.fullpath, team360_return_to: request.fullpath), class: tc_link_classes %>
                        · <span class="font-mono"><%= rec.status %></span>
                      <% elsif row.document_record_id %>
                        #<%= row.document_record_id %>
                      <% else %>
                        —
                      <% end %>
                    </td>
                    <td class="font-mono">
                      <% if rec&.verified_by %>
                        <%= rec.verified_by.email %>
                      <% end %>
                      <% if rec&.verified_on %>
                        <br/><%= rec.verified_on %>
                      <% end %>
                      <% if rec&.submitted_on %>
                        <br/>sub <%= rec.submitted_on %>
                      <% end %>
                    </td>
                    <td><%= rec&.rejection_reason.presence || "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
            </div>
            <p class="mt-2 text-xs text-slate-500">
              <%= link_to "Pending review queue", admin_document_reviews_path, class: tc_link_classes %>
            </p>
          </div>
        </section>
      <% else %>
        <section class="tc-panel tc-panel--muted">
          <div class="tc-panel__body text-sm text-slate-600">No focused engagement — document readiness not evaluated.</div>
        </section>
      <% end %>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Subcontractor context</div>
        </div>
        <div class="tc-panel__body">
          <% if @snapshot.subcontractor_rows.blank? %>
            <p class="text-sm text-slate-600">No incoming subcontractor PartyRelationship rows for this party.</p>
          <% else %>
            <ul class="text-sm space-y-3">
              <% @snapshot.subcontractor_rows.each do |row| %>
                <li class="border-b border-slate-100 pb-2 last:border-0">
                  <span class="font-mono text-xs text-slate-500">source → target</span>
                  <%= link_to row[:source_party].presence || "Party ##{row[:source_party_id]}", admin_party_path(row[:source_party_id]), class: tc_link_classes %>
                  · rel <%= row[:id] %> · <%= row[:status] %>
                  <% if row[:effective_start] || row[:effective_end] %>
                    · eff. <%= row[:effective_start] || "—" %> — <%= row[:effective_end] || "—" %>
                  <% end %>
                  <br/>
                  <% if row[:promoted] %>
                    <span class="tc-badge tc-badge--info">Promoted workforce</span>
                    <% if row[:subcontractor_engagement_status] %>
                      <span class="font-mono text-xs">subcontractor engagement <%= row[:subcontractor_engagement_status] %></span>
                    <% end %>
                  <% else %>
                    <span class="tc-badge tc-badge--neutral">Related-only</span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>

      <% if @snapshot.workforce_financial.present? && @snapshot.workforce_financial[:focused_engagement_id].present? %>
        <% fin = @snapshot.workforce_financial %>
        <section class="tc-panel">
          <div class="tc-panel__header">
            <div class="tc-panel__title">Compensation summary</div>
            <p class="tc-panel__subtitle">Focused engagement · <%= fin[:relationship_type] %></p>
          </div>
          <div class="tc-panel__body text-sm" style="color: var(--tc-text);">
            <% if fin[:assignment_summary].present? %>
              <ul class="list-none space-y-1 p-0 m-0 text-xs">
                <li><span class="font-medium"><%= fin[:assignment_summary][:plan_name] %>
                  (<%= fin[:assignment_summary][:plan_type] %>)</span></li>
                <li>Rate <%= tc_percent_from_bps(fin[:assignment_summary][:commission_rate_bps]) %></li>
                <% if fin[:assignment_summary][:minimum_amount_cents].to_i.positive? %>
                  <li>Min gross commission <%= tc_money(fin[:assignment_summary][:minimum_amount_cents]) %></li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-slate-600">No plan assignment effective on <%= @as_of_date %>.</p>
            <% end %>
            <% if fin[:admin_links].present? %>
              <p class="text-xs mt-3 space-x-3">
                <% if (href = fin[:admin_links][:revenue_inputs]).present? %>
                  <%= link_to "Revenue", href, class: tc_link_classes %>
                <% end %>
                <% if (href = fin[:admin_links][:commission_calculations]).present? %>
                  <%= link_to "Commission", href, class: tc_link_classes %>
                <% end %>
                <% if (href = fin[:admin_links][:contractor_charges]).present? %>
                  <%= link_to "Charges", href, class: tc_link_classes %>
                <% end %>
                <% if (href = fin[:admin_links][:settlement_runs_index]).present? %>
                  <%= link_to "Settlements", href, class: tc_link_classes %>
                <% end %>
              </p>
            <% end %>
            <% if fin[:draw_balance_cents].present? %>
              <p class="text-xs mt-2">Draw balance: <%= tc_money(fin[:draw_balance_cents]) %></p>
            <% end %>
          </div>
        </section>

        <% if fin[:contractor_charges].present? || fin[:last_settlement].present? || fin[:settlement].present? %>
          <section class="tc-panel">
            <div class="tc-panel__header">
              <div class="tc-panel__title">Contractor charges & settlement</div>
            </div>
            <div class="tc-panel__body text-sm space-y-2" style="color: var(--tc-text);">
              <% if fin[:contractor_charges].present? %>
                <p class="text-xs">
                  Open-ish charge rows: <%= fin[:contractor_charges][:open_count] %> ·
                  balance <%= tc_money(fin[:contractor_charges][:open_balance_cents]) %>
                </p>
                <% if fin[:contractor_charges][:past_due_count].to_i.positive? %>
                  <p class="text-xs text-amber-800">
                    Past due: <%= fin[:contractor_charges][:past_due_count] %> ·
                    <%= tc_money(fin[:contractor_charges][:past_due_balance_cents]) %>
                  </p>
                <% end %>
                <% if fin[:contractor_charges][:next_due_on].present? %>
                  <p class="text-xs">Next charge due: <%= fin[:contractor_charges][:next_due_on] %></p>
                <% end %>
                <% if fin[:contractor_charges][:recent_recoveries].present? %>
                  <p class="text-xs font-medium mt-2">Recent recoveries</p>
                  <ul class="list-none text-xs space-y-0.5 p-0 m-0 font-mono">
                    <% fin[:contractor_charges][:recent_recoveries].each do |r| %>
                      <li><%= r[:occurred_on] %> · <%= tc_money(r[:amount_cents]) %> · <%= r[:source_type] %> · charge <%= r[:contractor_charge_id] %></li>
                    <% end %>
                  </ul>
                <% end %>
                <% if fin[:contractor_charges][:recent_waivers].present? %>
                  <p class="text-xs font-medium mt-2">Recent waivers</p>
                  <ul class="list-none text-xs space-y-0.5 p-0 m-0 font-mono">
                    <% fin[:contractor_charges][:recent_waivers].each do |w| %>
                      <li><%= w[:created_at].in_time_zone.to_date %> · <%= tc_money(w[:amount_cents]) %> · charge <%= w[:contractor_charge_id] %></li>
                    <% end %>
                  </ul>
                <% end %>
              <% end %>
              <% if fin[:settlement].present? && fin[:settlement][:open_runs].present? %>
                <p class="text-xs font-medium mt-2">Open agency settlement runs</p>
                <ul class="list-none text-xs space-y-0.5 p-0 m-0 font-mono">
                  <% fin[:settlement][:open_runs].each do |r| %>
                    <li>#<%= r[:id] %> <%= r[:status] %> · <%= r[:period_start_on] %>–<%= r[:period_end_on] %></li>
                  <% end %>
                </ul>
              <% end %>
              <% if fin[:settlement].present? && fin[:settlement][:recent_lines].present? %>
                <p class="text-xs font-medium mt-2">Recent settlement lines (this engagement)</p>
                <ul class="list-none text-xs space-y-0.5 p-0 m-0 font-mono">
                  <% fin[:settlement][:recent_lines].each do |ln| %>
                    <li>
                      line <%= ln[:line_id] %> · run #<%= ln[:run_id] %> (<%= ln[:run_status] %>) ·
                      net <%= tc_money(ln[:net_cents]) %> · <%= ln[:period_start_on] %>–<%= ln[:period_end_on] %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
              <% if fin[:last_settlement].present? %>
                <p class="text-xs font-mono mt-2">
                  Last line: run #<%= fin[:last_settlement][:run_id] %>
                  (<%= fin[:last_settlement][:status] %>)
                  · net <%= tc_money(fin[:last_settlement][:net_cents]) %>
                  · <%= fin[:last_settlement][:period_start_on] %>–<%= fin[:last_settlement][:period_end_on] %>
                </p>
              <% else %>
                <p class="text-xs text-slate-600">No settlement lines yet.</p>
              <% end %>
            </div>
          </section>
        <% end %>
      <% end %>

      <% unless @snapshot.weekly_timesheets_panel.nil? %>
        <section class="tc-panel">
          <div class="tc-panel__header">
            <div class="tc-panel__title">Weekly timesheets</div>
            <p class="tc-panel__subtitle">
              Read-only summary for the focused employee engagement.
              <%= link_to "Pending approvals queue", admin_weekly_timesheets_path, class: "#{tc_link_classes} text-xs ml-1" %>
            </p>
          </div>
          <div class="tc-panel__body text-sm space-y-3">
            <% if @snapshot.weekly_timesheets_panel.empty? %>
              <p class="text-slate-600">No weekly timesheets recorded yet.</p>
            <% end %>
            <% @snapshot.weekly_timesheets_panel.each do |row| %>
              <div class="border rounded-md p-3" style="border-color: var(--tc-border);">
                <div class="flex flex-wrap justify-between gap-2">
                  <span class="font-medium">
                    <%= row[:week_start_on] %> – <%= row[:week_end_on] %>
                  </span>
                  <span class="font-mono text-xs"><%= row[:status] %></span>
                </div>
                <p class="text-xs mt-1 text-slate-600">
                  REG <%= row[:regular_hours] %> h · OT <%= row[:overtime_hours] %> h
                  · <strong><%= row[:overtime_visibility] %></strong> overtime visibility
                </p>
                <% if row[:submitted_at].present? %>
                  <p class="text-xs text-slate-600">Submitted <%= row[:submitted_at].in_time_zone.to_date %></p>
                <% end %>
                <% if row[:approved_at].present? %>
                  <p class="text-xs text-slate-600">Approved <%= row[:approved_at].in_time_zone.to_date %></p>
                <% end %>
                <% if row[:approval_events].present? %>
                  <p class="text-xs font-medium mt-2">Recent approval activity</p>
                  <ul class="list-none text-xs space-y-0.5 p-0 m-0 font-mono text-slate-600">
                    <% row[:approval_events].each do |ev| %>
                      <li>
                        <%= ev[:occurred_at].in_time_zone.to_fs(:db) %>
                        · <%= ev[:event_type] %>
                        · <%= ev[:transition_from] %> → <%= ev[:transition_to] %>
                        <% if ev[:reason].present? %> — <%= ev[:reason] %><% end %>
                      </li>
                    <% end %>
                  </ul>
                <% end %>
                <%= link_to "Open in admin", admin_weekly_timesheet_path(row[:id]), class: "#{tc_link_classes} text-xs mt-2 inline-block" %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <% unless @snapshot.leave_panel.nil? %>
        <section class="tc-panel">
          <div class="tc-panel__header">
            <div class="tc-panel__title">Leave</div>
            <p class="tc-panel__subtitle">
              Read-only balances and recent requests for the focused employee engagement.
              <%= link_to "Leave queue", admin_leave_requests_path, class: "#{tc_link_classes} text-xs ml-1" %>
            </p>
          </div>
          <div class="tc-panel__body text-sm space-y-3">
            <% if @snapshot.leave_panel[:balances].blank? %>
              <p class="text-slate-600">No balance-tracked leave buckets recorded yet.</p>
            <% else %>
              <p class="text-xs font-medium">Balances (balance-tracked types)</p>
              <ul class="list-none space-y-1 p-0 m-0 text-xs font-mono text-slate-700">
                <% @snapshot.leave_panel[:balances].each do |b| %>
                  <li><%= b[:leave_type_code] %> · <%= b[:balance_hours] %> h</li>
                <% end %>
              </ul>
            <% end %>

            <% if @snapshot.leave_panel[:requests].blank? %>
              <p class="text-slate-600">No leave requests recorded yet.</p>
            <% else %>
              <% @snapshot.leave_panel[:requests].each do |row| %>
                <div class="border rounded-md p-3" style="border-color: var(--tc-border);">
                  <div class="flex flex-wrap justify-between gap-2">
                    <span class="font-medium"><%= row[:leave_type_code] %></span>
                    <span class="font-mono text-xs"><%= row[:status] %></span>
                  </div>
                  <p class="text-xs mt-1 text-slate-600">
                    Policy: <span class="font-mono"><%= row[:approval_policy] %></span>
                    <% if row[:auto_approved] %>
                      · <span class="text-emerald-700">Auto-approved</span>
                    <% end %>
                  </p>
                  <% if row[:start_on].present? && row[:end_on].present? %>
                    <p class="text-xs mt-1 text-slate-600"><%= row[:start_on] %> – <%= row[:end_on] %></p>
                  <% end %>
                  <p class="text-xs mt-1"><strong><%= row[:visibility_label] %></strong></p>
                  <% if row[:days].present? %>
                    <ul class="list-none text-xs space-y-0.5 p-0 m-0 font-mono text-slate-600 mt-2">
                      <% row[:days].each do |d| %>
                        <li><%= d[:leave_date] %> · <%= d[:hours] %> h</li>
                      <% end %>
                    </ul>
                  <% end %>
                  <% if row[:events].present? %>
                    <p class="text-xs font-medium mt-2">Recent activity</p>
                    <ul class="list-none text-xs space-y-0.5 p-0 m-0 font-mono text-slate-600">
                      <% row[:events].each do |ev| %>
                        <li>
                          <%= ev[:occurred_at].in_time_zone.to_fs(:db) %>
                          · <%= ev[:event_type] %>
                          · <%= ev[:transition_from] %> → <%= ev[:transition_to] %>
                          <% if ev[:actor_email].present? %>
                            · <%= ev[:actor_email] %>
                          <% elsif ev[:actor_kind].present? %>
                            · <%= ev[:actor_kind] == "system_policy" ? "system policy" : ev[:actor_kind] %>
                          <% end %>
                          <% if ev[:reason].present? %> — <%= ev[:reason] %><% end %>
                        </li>
                      <% end %>
                    </ul>
                  <% end %>
                  <%= link_to "Open in admin", admin_leave_request_path(row[:id]), class: "#{tc_link_classes} text-xs mt-2 inline-block" %>
                </div>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>

      <% %w[
        payroll audit_timeline
      ].each do |key| %>
        <section class="tc-panel tc-panel--muted">
          <div class="tc-panel__header">
            <div class="tc-panel__title"><%= key.humanize %></div>
            <p class="tc-panel__subtitle">Deferred domain — placeholder only.</p>
          </div>
          <div class="tc-panel__body text-sm text-slate-600">
            This panel is not implemented in Phase 3.
          </div>
        </section>
      <% end %>
    </div>

    <aside class="tc-record-context tc-record-context--sticky">
      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Quick links</div>
        </div>
        <div class="tc-panel__body text-sm space-y-2">
          <%= link_to "Team member admin", admin_team_member_path(@team_member), class: "block #{tc_link_classes}" %>
          <%= link_to "Party", admin_party_path(@snapshot.identity[:party_id]), class: "block #{tc_link_classes}" %>
          <% @snapshot.engagement_summaries.first(5).each do |s| %>
            <%= link_to "Engagement ##{s[:id]}", admin_engagement_path(s[:id], return_to: request.fullpath, team360_return_to: request.fullpath), class: "block #{tc_link_classes}" %>
          <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
