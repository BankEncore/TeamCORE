<% content_for :title, "Placements — Engagement ##{@engagement.id}" %>
<div class="mb-4 flex flex-wrap gap-2 items-center">
  <%= link_to "← Engagement", admin_engagement_path(@engagement), class: "text-sky-700 text-sm" %>
  <%= link_to "New placement", new_admin_engagement_placement_path(@engagement), class: "rounded bg-slate-900 text-white px-3 py-2 text-sm" %>
</div>
<h1 class="text-2xl font-semibold mb-4">Placements</h1>
<ul class="divide-y border border-slate-200 rounded bg-white">
  <% @placements.each do |p| %>
    <li class="px-4 py-3 text-sm">
      <%= link_to "#{p.effective_start_on} → #{p.effective_end_on || 'open'}", admin_engagement_placement_path(@engagement, p), class: "text-sky-700 underline font-medium" %>
    </li>
  <% end %>
</ul>
