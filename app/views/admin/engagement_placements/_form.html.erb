<%= render "shared/errors", model: @placement %>
<%= form_with model: @placement,
      url: @placement.persisted? ? admin_engagement_placement_path(@engagement, @placement) : admin_engagement_placements_path(@engagement),
      method: @placement.persisted? ? :patch : :post,
      data: { turbo: false } do |f| %>
  <div class="mb-3">
    <%= f.label :department_id, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.collection_select :department_id, @departments, :id, :name, { include_blank: "—" }, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :location_id, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.collection_select :location_id, @locations, :id, :name, { include_blank: "—" }, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :team_id, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.collection_select :team_id, @teams, :id, :name, { include_blank: "—" }, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :effective_start_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.date_field :effective_start_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-3">
    <%= f.label :effective_end_on, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.date_field :effective_end_on, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <div class="mb-4">
    <%= f.label :notes, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :notes, rows: 2, class: "w-full border border-slate-300 rounded px-3 py-2" %>
  </div>
  <%= f.submit class: "rounded bg-slate-900 text-white px-4 py-2 text-sm cursor-pointer" %>
<% end %>
