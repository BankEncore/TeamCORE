<%= form_with model: [:admin, source_party, party_relationship], class: "space-y-4 max-w-xl" do |f| %>
  <% if party_relationship.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-900 rounded px-3 py-2 text-sm">
      <ul class="list-disc pl-5">
        <% party_relationship.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <p class="text-sm text-slate-600 mb-1">Source (fixed)</p>
    <p class="font-medium"><%= source_party.display_name.presence || "Party ##{source_party.id}" %></p>
  </div>

  <div>
    <%= f.label :target_party_id, "Target party", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.collection_select :target_party_id, target_parties, :id, ->(p) { p.display_name.presence || "Party ##{p.id}" }, { include_blank: "Select target…" }, class: "border border-slate-300 rounded w-full px-2 py-1 text-sm" %>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :status, LifecycleStatusable::STATUSES, {}, class: "border border-slate-300 rounded w-full px-2 py-1 text-sm" %>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :effective_start_date, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :effective_start_date, class: "border border-slate-300 rounded w-full px-2 py-1 text-sm" %>
    </div>
    <div>
      <%= f.label :effective_end_date, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :effective_end_date, class: "border border-slate-300 rounded w-full px-2 py-1 text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :notes, rows: 3, class: "border border-slate-300 rounded w-full px-2 py-1 text-sm font-mono" %>
  </div>

  <%= f.submit class: "rounded bg-slate-900 text-white px-4 py-2 text-sm cursor-pointer" %>
<% end %>
