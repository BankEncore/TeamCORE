<% content_for :title, "Subcontractor relationships — #{@source_party.display_name.presence || 'Party'}" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">People</p>
      <h1 class="tc-page-header__title"><%= outbound_subcontractors_panel_title(@source_party) %></h1>
      <p class="tc-page-header__subtitle">
        Source party: <%= @source_party.display_name.presence || "Party ##{@source_party.id}" %> (subcontractor PartyRelationships only).
      </p>
    </div>
    <div class="tc-page-header__actions">
      <div class="tc-action-bar">
        <%= link_to "← Party", admin_party_path(@source_party), class: "#{tc_link_classes} text-sm" %>
        <%= link_to "New subcontractor relationship", new_admin_party_party_relationship_path(@source_party), class: "tc-btn tc-btn--primary" %>
      </div>
    </div>
  </header>

  <% if @party_relationships.empty? %>
    <p class="text-sm" style="color: var(--tc-text-muted);">No subcontractor relationships yet.</p>
  <% else %>
    <div class="tc-panel p-0">
      <ul class="m-0 divide-y list-none p-0" style="border-color: var(--tc-border);">
        <% @party_relationships.each do |rel| %>
          <li class="p-4 text-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <div class="font-medium" style="color: var(--tc-text);">
                  <span style="color: var(--tc-text-muted);">Source → Target:</span>
                  <%= @source_party.display_name %> → <%= rel.target_party.display_name.presence || "Party ##{rel.target_party_id}" %>
                </div>
                <div class="mt-1 flex flex-wrap items-center gap-2">
                  <span class="<%= tc_status_badge_classes(rel.status) %>"><%= rel.status %></span>
                  <% if rel.effective_start_date || rel.effective_end_date %>
                    <span class="text-xs" style="color: var(--tc-text-muted);">
                      effective <%= rel.effective_start_date || "—" %> — <%= rel.effective_end_date || "—" %>
                    </span>
                  <% end %>
                </div>
                <div class="mt-1 text-xs" style="color: var(--tc-text-muted);">
                  <%= subcontractor_workforce_tier_label(rel.target_party, current_agency) %>
                </div>
                <% if rel.subcontractor_person_source_stale_for_display? %>
                  <div class="tc-alert tc-alert--warning mt-2 text-xs">
                    Warning: person source is no longer contractor-capable (no active individual contractor engagement). Existing history remains; edits require a current eligible source or end-dating this relationship.
                  </div>
                <% end %>
              </div>
              <div class="flex flex-wrap gap-2">
                <%= link_to "Edit", edit_admin_party_party_relationship_path(@source_party, rel), class: "tc-btn tc-btn--secondary" %>
                <% if rel.promotion_eligible? %>
                  <%= button_to "Promote", promote_admin_party_party_relationship_path(@source_party, rel), method: :post, class: "tc-btn tc-btn--teal", form: { class: "inline" } %>
                <% elsif rel.subcontractor? %>
                  <span class="text-xs" style="color: var(--tc-text-muted);" title="Requires active/effective relationship, eligible source, complete target identity">Promote unavailable</span>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
