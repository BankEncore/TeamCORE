<% content_for :title, "Team members — TeamCORE Admin" %>
<div class="tc-page-stack">
  <header class="tc-page-header">
    <div>
      <p class="tc-page-header__eyebrow">People</p>
      <h1 class="tc-page-header__title">Team members</h1>
      <p class="tc-page-header__subtitle">
        Employee, contractor, and affiliate workforce records linked to parties in this agency.
      </p>
    </div>
    <div class="tc-page-header__actions">
      <div class="tc-action-bar">
        <%= link_to "New team member", new_admin_team_member_path, class: "tc-btn tc-btn--primary" %>
      </div>
    </div>
  </header>

  <div class="tc-table-wrap">
    <table class="tc-data-table">
      <thead>
        <tr>
          <th>Party</th>
          <th>Number</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @team_members.each do |tm| %>
          <tr>
            <td class="tc-data-table__primary">
              <%= link_to(tm.party.display_name.presence || "TM ##{tm.id}", admin_team_member_path(tm), class: tc_link_classes) %>
            </td>
            <td class="tc-data-table__cell-muted"><%= tm.team_member_number.presence || "—" %></td>
            <td>
              <span class="<%= tc_status_badge_classes(tm.status) %>"><%= tm.status %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
