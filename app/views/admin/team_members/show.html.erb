<% content_for :title, "TM ##{@team_member.id} — Team member" %>
<div class="tc-page-stack">
  <p class="text-sm">
    <%= link_to "← Team members", admin_team_members_path, class: tc_link_classes %>
  </p>

  <header class="tc-record-header">
    <div class="tc-record-header__top">
      <div>
        <div class="tc-record-header__eyebrow">People</div>
        <h1 class="tc-record-header__title"><%= @team_member.party.display_name.presence || "Team member ##{@team_member.id}" %></h1>
        <p class="tc-record-header__subtitle">
          Team member #<%= @team_member.id %>
          <% if @team_member.team_member_number.present? %>
            · <%= @team_member.team_member_number %>
          <% end %>
        </p>
        <div class="tc-record-header__badges">
          <span class="<%= tc_status_badge_classes(@team_member.status) %>"><%= @team_member.status %></span>
        </div>
      </div>
      <div class="tc-record-header__actions">
        <%= link_to "Team360", admin_team_member_team360_path(@team_member), class: "tc-btn tc-btn--teal" %>
        <%= link_to "Edit", edit_admin_team_member_path(@team_member), class: "tc-btn tc-btn--secondary" %>
      </div>
    </div>
  </header>

  <div class="tc-record-layout">
    <section class="tc-record-main">
      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Identity</div>
        </div>
        <div class="tc-panel__body">
          <dl class="tc-kv-grid">
            <div class="tc-kv">
              <dt class="tc-kv__key">Party</dt>
              <dd class="tc-kv__value">
                <%= link_to(@team_member.party.display_name.presence || "Party ##{@team_member.party_id}", admin_party_path(@team_member.party), class: tc_link_classes) %>
              </dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Team member number</dt>
              <dd class="tc-kv__value"><%= @team_member.team_member_number.presence || "—" %></dd>
            </div>
          </dl>
        </div>
      </section>

      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Subcontractor relationships (incoming)</div>
          <p class="tc-panel__subtitle">PartyRelationships where this team member&apos;s party is the target.</p>
        </div>
        <div class="tc-panel__body">
          <% if @incoming_subcontractor_rels.blank? %>
            <p class="text-sm" style="color: var(--tc-text-muted);">None.</p>
          <% else %>
            <ul class="m-0 list-none space-y-2 p-0 text-sm">
              <% @incoming_subcontractor_rels.each do |rel| %>
                <li class="border-b pb-2 last:border-0" style="border-color: var(--tc-border);">
                  <span class="font-mono text-xs" style="color: var(--tc-text-muted);">source → target</span>
                  <%= rel.source_party.display_name.presence || "Party ##{rel.source_party_id}" %> → <%= @team_member.party.display_name %>
                  · <span class="<%= tc_status_badge_classes(rel.status) %>"><%= rel.status %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>
    </section>

    <aside class="tc-record-context tc-record-context--sticky">
      <section class="tc-panel">
        <div class="tc-panel__header">
          <div class="tc-panel__title">Quick facts</div>
        </div>
        <div class="tc-panel__body">
          <dl class="tc-kv-grid tc-kv-grid--single">
            <div class="tc-kv">
              <dt class="tc-kv__key">Record id</dt>
              <dd class="tc-kv__value font-mono text-xs"><%= @team_member.id %></dd>
            </div>
            <div class="tc-kv">
              <dt class="tc-kv__key">Party id</dt>
              <dd class="tc-kv__value font-mono text-xs"><%= @team_member.party_id %></dd>
            </div>
          </dl>
        </div>
      </section>
    </aside>
  </div>
</div>
