<% content_for :title, "Sign in — TeamCORE" %>
<div class="max-w-md mx-auto mt-24 px-4">
  <h1 class="text-xl font-semibold mb-4">Sign in</h1>
  <% if flash[:alert].present? %>
    <p class="text-red-700 text-sm mb-4"><%= flash[:alert] %></p>
  <% end %>
  <%= form_with url: login_path, method: :post, data: { turbo: false } do |f| %>
    <div class="mb-3">
      <%= label_tag :email, "Email", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= email_field_tag :email, params[:email], class: "w-full border border-slate-300 rounded px-3 py-2", autocomplete: "username" %>
    </div>
    <div class="mb-4">
      <%= label_tag :password, "Password", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= password_field_tag :password, nil, class: "w-full border border-slate-300 rounded px-3 py-2", autocomplete: "current-password" %>
    </div>
    <%= submit_tag "Sign in", class: "w-full rounded bg-slate-900 text-white py-2 text-sm cursor-pointer hover:bg-slate-800" %>
  <% end %>
</div>
